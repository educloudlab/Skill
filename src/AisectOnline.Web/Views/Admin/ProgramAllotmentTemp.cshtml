@model AisectOnline.Services.Modules.MasterData.ProgrammeAllotment
@using AisectOnline.Services.Modules.MasterData
@using DevExtreme.AspNet.Mvc

@{
    Layout = "_Layout";
}
<link href="~/css/templatecss/programallotment.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet" />
<link href="~/css/devextreme/dx.light.css" rel="stylesheet" />
<link href="~/css/allotmentgrid.css" rel="stylesheet" />

<div class="page">
    <div class="header-box">
        <div class="title">Program Allocate</div>
        <div class="underline"></div>
        <div class="subtitle">Allocate / Reallocate programmes to KIOSK</div>
    </div>

    <div class="tabs" role="tab">
        <div id="tabKiosk" class="tab" data-tab="KIOSK" onclick="openTab('KIOSK')">Kiosk Service</div>
        <div id="tabProgramme" class="tab" data-tab="PROGRAME" onclick="openTab('Programme')">Programme</div>
    </div>

    <!-- ================= KIOSK (ORIGINAL) ================= -->
    <div id="kioskCard" class="master-card" style="display:none;">
        <div class="prog-card">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
                <label style="font-weight:800;">Program</label>
                <button id="toggleOptionsBtn" type="button" onclick="toggleOptions()"
                        style="display:none;border:0;background:#e8fff1;color:#11a84b;padding:6px 12px;border-radius:999px;font-weight:700;cursor:pointer;">
                    <i class="fa fa-eye"></i> Show/Hide
                </button>
            </div>

            <div id="programOptions">
                <div class="pill-title">Programme Options</div>
                <div class="pill-group" id="pillGroup">
                    <label class="pill-radio" id="pillMulti" onclick="selectPill(this, 'MultiService')">
                        <input type="radio" name="progPill" value="MultiService" />
                        <span class="pill-dot"></span><span class="pill-text">MultiService Only</span>
                    </label>
                    <label class="pill-radio" id="pillEdu" onclick="selectPill(this, 'Educational')">
                        <input type="radio" name="progPill" value="Educational" />
                        <span class="pill-dot"></span><span class="pill-text">Educational (Assigned later MultiService)</span>
                    </label>
                </div>

                <div id="inlineDropdown" class="inline-dropdown" style="display:none;">
                    <div class="_kiosk-title">KIOSK</div>
                    @(Html.DevExtreme().Lookup()
                                        .ID("KioskID")
                                        .DataSource(ds => ds.Mvc().Controller("Admin").LoadAction("GetKioskList").Key("ValueField"))
                                        .DisplayExpr("TextField").ValueExpr("ValueField")
                                        .SearchEnabled(true).MinSearchLength(2)
                                        .PageLoadMode(ListPageLoadMode.ScrollBottom)
                                        .DropDownOptions(o => o.Height(400))
                                        .SearchTimeout(500)
                                        .OnValueChanged("function(e){ OnChangeKioskId(e); }")
                                        )
                </div>

                <div id="servicesBlock" class="inline-dropdown" style="display:none">
                    <div class="_kiosk-title">University</div>
                    @(Html.DevExtreme().SelectBox()
                                        .ID("Services").Name("Services").DataSource(new JS("[]"))
                                        .DisplayExpr("TextField").ValueExpr("ValueField")
                                        .Placeholder("Please Select")
                                        .ValidationRules(r => { r.AddRequired().Message("Services is required."); })
                                        .OnValueChanged("function(e){ OnChangeServices(e); }")
                                        )
                </div>

                <div id="facultyBlock" class="inline-dropdown" style="display:none">
                    <div class="_kiosk-title">Faculty/Academy</div>
                    @(Html.DevExtreme().SelectBox()
                                        .ID("FacultyId").Name("FacultyId").DataSource(new JS("[]"))
                                        .DisplayExpr("TextField").ValueExpr("ValueField")
                                        .Placeholder("Please Select")
                                        .ValidationRules(r => { r.AddRequired().Message("Services is required."); })
                                        .OnValueChanged("function(e){ OnChangeFaculty(e); }")
                                        )
                </div>
                <div id="programmeDropdownBlock" class="inline-dropdown" style="display:none;margin-top:10px;">
                    <div class="_kiosk-title">PROGRAMME</div>
                    @(Html.DevExtreme().Lookup()
                                        .ID("ProgrammeSelect")
                                        .DataSource(ds => ds.Mvc().Controller("Admin").LoadAction("GetAllPrograms1").Key("ValueField"))
                                        .DisplayExpr("TextField").ValueExpr("ValueField")
                                        .SearchEnabled(true).MinSearchLength(2)
                                        .PageLoadMode(ListPageLoadMode.ScrollBottom)
                                        .DropDownOptions(o => o.Height(400))
                                        .SearchTimeout(500)
                                        )
                </div>

            </div>

            <!-- KIOSK breadcrumbs -->
            <div id="progInfo" class="prog-info" style="display:none;">
                <div class="chips">
                    <span id="chipKiosk" class="chip chip-k">Kiosk: –</span>
                    <span id="chipUniv" class="chip chip-u">University: –</span>
                    <span id="chipFac" class="chip chip-f">Faculty: –</span>
                </div>
                <div class="counts">
                    <span class="badge" id="badgeAvail">Available: 0</span>
                    <span class="badge" id="badgeAllot">Allotted: 0</span>
                </div>
            </div>

            <div class="actions-row" id="kioskActions" style="display:none;">
                @(Html.DevExtreme().Button()
                                .ID("loadBtn")
                                .Text("Load Programmes")
                                .Type(ButtonType.Default)
                                .OnClick("function() { Show(); }")
                                .Width("160px"))
                <button class="btn msc" onclick="mscAllot()">MSC &amp; FI Allotment</button>
            </div>
        </div>

        <div id="kioskBlock" class="grid-wrap" aria-live="polite"></div>
        <div id="allotmentContainer"></div>
        <div style="text-align:center;">
            <button id="updateBtn" class="update-btn" onclick="updateAllotment()" style="display:none;">
                <i class="fa fa-check"></i>&nbsp;&nbsp;Update
            </button>
        </div>
    </div>

</div>
<script>
               // ===================== LOAD AND CLEAR =====================
    function Show(){
           const activeTab = getActiveTab();
           if(activeTab === 'KIOSK'){
               const kioskId=getDxVal("KioskID",'lookup');
             const serviceId=getDxVal("Services",'select');
             const facultyId=getDxVal("FacultyId",'select');
             if(!kioskId||!serviceId||!facultyId){ notify("Please select Kiosk, Service and Faculty before submit","warning",2200); return; }
             debugger;
             // Dynamically load partial view
              $("#allotmentContainer").load('@Url.Action("LoadAllotmentArea2", "Admin")',
           { KioskId: kioskId, serviceId: serviceId, IsAlloted: 0, CourseCategoryId: facultyId },
           function () {
               $("#allotArea").show();
               setCounts();
               $("#updateBtn").show();

               // Load ALREADY-ALLOTTED programs after left side loaded
               $.get('@Url.Action("GetCheckBoxForProgramAllotment", "Admin")',
                 { KioskId: kioskId, serviceId: serviceId, IsAlloted: 1, CourseCategoryId: facultyId },
                 d => {
                   destPrograms = d || [];
                   renderDest();
                   setCounts();
                 });
           });

           }
            else if(activeTab === 'PROGRAME'){
                   const ProgramId=getDxVal("ProgrammeSelect",'lookup');
                 if(!ProgramId){ notify("Please Programme before submit","warning",2200); return; }
                 debugger;
                 // Dynamically load partial view
                  $("#allotmentContainer").load('@Url.Action("LoadAllotmentArea2", "Admin")',
               { programId: ProgramId, IsAlloted: 0 },
               function () {
                   $("#allotArea").show();
                   setCounts();
                   $("#updateBtn").show();

                   // Load ALREADY-ALLOTTED programs after left side loaded
                   $.get('@Url.Action("GetCheckBoxForProgramAllotment", "Admin")',
                     { programId: ProgramId, IsAlloted: 1 },
                     d => {
                       destPrograms = d || [];
                       renderDest();
                       setCounts();
                     });
               });

               }

           }

        function setCounts(){
          document.getElementById('badgeAvail').textContent="Available: "+(availablePrograms?.length||0);
          document.getElementById('badgeAllot').textContent="Allotted: "+((destPrograms?.length||0)+(allottedPrograms?.length||0));
        }
            function resetCounts() {
          document.getElementById('badgeAvail').textContent = "Available: 0";
          document.getElementById('badgeAllot').textContent = "Allotted: 0";
        }

            function selectPill(labelEl, value) {
          // Remove previous selection
          document.querySelectorAll('#pillGroup .pill-radio').forEach(p => {
            p.classList.remove('selected');
            const i = p.querySelector('input');
            if (i) i.checked = false;
          });

          // Set new selection
          labelEl.classList.add('selected');
          const inp = labelEl.querySelector('input');
          if (inp) inp.checked = true;

          // Determine active tab
          const activeTab = document.querySelector('.tab.active')?.dataset.tab;

          // Hide all blocks first
          document.getElementById('inlineDropdown').style.display = 'none';
          document.getElementById('servicesBlock').style.display = 'none';
          document.getElementById('facultyBlock').style.display = 'none';
          document.getElementById('programmeDropdownBlock').style.display = 'none';

          // Logic depending on tab
          if (activeTab === 'Programme') {
            // ✅ Only show programme dropdown
            document.getElementById('programmeDropdownBlock').style.display = 'flex';
          } else if (activeTab === 'KIOSK') {
            // ✅ Show all 3 blocks for KIOSK
            document.getElementById('inlineDropdown').style.display = 'flex';
            document.getElementById('servicesBlock').style.display = 'flex';
            document.getElementById('facultyBlock').style.display = 'flex';
          }

          // Always show Kiosk action section if in kiosk tab
          if (activeTab === 'KIOSK') {
            document.getElementById('kioskActions').style.display = '';
            updateKioskBreadcrumbs(true);
          }
        }
        function openTab(tab) {
      // Reset active states
      document.getElementById('tabKiosk').classList.remove('active');
      document.getElementById('tabProgramme').classList.remove('active');

      // Hide both cards initially
      const kioskCard = document.getElementById('kioskCard');
      const programmeCard = document.getElementById('programmeCard');
      if (kioskCard) kioskCard.style.display = 'none';
      if (programmeCard) programmeCard.style.display = 'none';

      // Hide all conditional blocks
      document.getElementById('inlineDropdown').style.display = 'none';
      document.getElementById('servicesBlock').style.display = 'none';
      document.getElementById('facultyBlock').style.display = 'none';
      document.getElementById('programmeDropdownBlock').style.display = 'none';
      document.getElementById('kioskActions').style.display = 'none';
      //document.getElementById('allotArea').style.display = 'grid';
      document.getElementById('updateBtn').style.display = 'none';

      // Reset counts and form
      resetCounts();
      clearFrom();

      const pillSelected = document.querySelector('#pillGroup .pill-radio.selected');

      // ---------------------------
      //  PROGRAMME TAB
      // ---------------------------
      if (tab === 'Programme') {
        document.getElementById('tabProgramme').classList.add('active');
        if (programmeCard) programmeCard.style.display = 'block';
        if (kioskCard) kioskCard.style.display = 'block';

        if (pillSelected) {
          document.getElementById('programmeDropdownBlock').style.display = 'flex';
          document.getElementById('kioskActions').style.display = '';
          updateKioskBreadcrumbs(true);
        }

      // ---------------------------
      //  KIOSK TAB
      // ---------------------------
      } else if (tab === 'KIOSK') {
        document.getElementById('tabKiosk').classList.add('active');
        if (kioskCard) kioskCard.style.display = 'block';
        if (programmeCard) programmeCard.style.display = 'block';

        if (pillSelected) {
          document.getElementById('inlineDropdown').style.display = 'flex';

          // Only show these if values exist
          if (getDxVal("KioskID", 'lookup'))
            document.getElementById('servicesBlock').style.display = 'flex';
          if (getDxVal("Services", 'select'))
            document.getElementById('facultyBlock').style.display = 'flex';

          document.getElementById('kioskActions').style.display = '';
          updateKioskBreadcrumbs(true);
        }

        // If grid data already loaded
        if ((availablePrograms?.length || 0) + (allottedPrograms?.length || 0) + (destPrograms?.length || 0) > 0) {
          document.getElementById('allotArea').style.display = 'grid';
          document.getElementById('updateBtn').style.display = '';
        }
      }
    }
         function updateKioskBreadcrumbs(show=true){
          document.getElementById('chipKiosk').textContent = "Kiosk: " + (getDxText("KioskID",'lookup') || "–");
          document.getElementById('chipUniv').textContent  = "University: " + (getDxText("Services",'select') || "–");
          document.getElementById('chipFac').textContent   = "Faculty: " + (getDxText("FacultyId",'select') || "–");
          document.getElementById('progInfo').style.display = show ? 'flex' : 'none';
        }
        function OnChangeKioskId(e){
          resetSelectBox("Services"); resetSelectBox("FacultyId");
          if(safeLeft()) safeLeft().option("dataSource",[]); if(safeRight()) safeRight().option("dataSource",[]);
          updateKioskBreadcrumbs(true);
          if(!e.value) return;
          $.get('/Admin/Getservices',{Kioskid:e.value},data=>{
            const sb=DevExpress.ui.dxSelectBox.getInstance(document.getElementById("Services"));
            if(sb) sb.option({dataSource:data,valueExpr:"ValueField",displayExpr:"TextField",value:null});
          });
        }
        function OnChangeServices(e){
          resetSelectBox("FacultyId");
          updateKioskBreadcrumbs(true);
          const kioskId=getDxVal("KioskID",'lookup');
          if(!(kioskId&&e.value)) return;
          $.get('/Admin/GetCourseCtgByServiceId',{KioskId:kioskId,serviceId:e.value},data=>{
            const fb=DevExpress.ui.dxSelectBox.getInstance(document.getElementById("FacultyId"));
            if(fb) fb.option({dataSource:data,valueExpr:"ValueField",displayExpr:"TextField",value:null});
          });
        }
        function OnChangeFaculty(e){ updateKioskBreadcrumbs(true); }

        //------------------------------------------------

        function getActiveTab() {
            const activeTab = document.querySelector('.tabs .tab.active');
            return activeTab ? activeTab.dataset.tab || activeTab.id : null;
        }
        var availablePrograms = [], allottedPrograms = [], destPrograms = [];

        function safeLeft(){try{return $("#gridContainer").dxDataGrid("instance");}catch(e){return null;}}
        function safeRight(){try{return $("#gridContainer2").dxDataGrid("instance");}catch(e){return null;}}

        function notify(msg,type="info",time=1500){
          DevExpress.ui.notify({
            message:msg,type:type,displayTime:time,width:220,
            position:{my:"top right",at:"top right",of:".academy-outer"}
          });
        }

        function renderLeft(data){
          availablePrograms=data||[];
          $("#gridContainer").dxDataGrid({
            dataSource:availablePrograms,
            keyExpr:"ValueField",
            columns:[{dataField:"TextField",caption:"Programme Name"}],
            selection:{mode:"multiple",showCheckBoxesMode:"always"},
            paging:{enabled:false},showBorders:true,height:260,onContentReady:setCounts
          });
        }

        function renderDest(){
          $("#gridContainer2").dxDataGrid({
            dataSource: destPrograms.concat(allottedPrograms),
            keyExpr: "ValueField",
            columns: [{ dataField: "TextField", caption: "Programme Name" }],
            selection: { mode: "multiple", showCheckBoxesMode: "always" },
            paging: { enabled: false }, showBorders: true, height: 260,

            rowPrepared: function(e){
              if(e.rowType === "data" && destPrograms.some(d => d.ValueField === e.data.ValueField)){
                e.rowElement.addClass("disabled-row");
                e.rowElement.find("input[type=checkbox]").prop("disabled", true);
              }
            },

            onSelectionChanged: function(e){
              var disabledKeys = destPrograms.map(d => d.ValueField);
              var stillSelected = e.selectedRowKeys.filter(k => disabledKeys.includes(k));
              if(stillSelected.length){
                e.component.deselectRows(stillSelected);
                stillSelected.forEach(function(key){
                  var rowIndex = e.component.getRowIndexByKey(key);
                  if(rowIndex >= 0){
                    var rowElement = e.component.getRowElement(rowIndex);
                    rowElement.addClass("disabled-row");
                  }
                });
              }
            },

            onContentReady: function(e){
              try{
                  setCounts();
                var comp = e.component;
                var visible = comp.getVisibleRows ? comp.getVisibleRows() : [];
                visible.forEach(function(r){
                  if(r && r.data && destPrograms.some(d => d.ValueField === r.data.ValueField)){
                    var rowEl = comp.getRowElement(r.rowIndex);
                    if(rowEl && rowEl.length){
                      rowEl.addClass("disabled-row");
                      rowEl.find("input[type=checkbox]").prop("disabled", true);
                    }
                  }
                });
              }catch(ex){}
            }
          });
        }


        function clearFrom(){
          try { $('#AcademyId1').dxSelectBox('instance').option('value', null); } catch(e){}
          $("#allotmentContainer").empty();
          availablePrograms=[]; allottedPrograms=[]; destPrograms=[];
          $("#updateBtn").hide();
        }

        // ===================== ADD / REMOVE FUNCTIONS =====================
        function addSelected(){
          var left=safeLeft(); if(!left)return;
          var rows=left.getSelectedRowsData(); if(!rows.length){notify("Select items to add","warning");return;}
          rows.forEach(r=>{
            if(!allottedPrograms.some(a=>a.ValueField===r.ValueField)
               && !destPrograms.some(a=>a.ValueField===r.ValueField)){
                 allottedPrograms.push(r);
                 availablePrograms=availablePrograms.filter(a=>a.ValueField!==r.ValueField);
            }
          });
          renderLeft(availablePrograms);renderDest();
        }

        function addAll(){
          if(!availablePrograms.length){notify("No programmes","warning");return;}
          availablePrograms.forEach(r=>{
            if(!allottedPrograms.some(a=>a.ValueField===r.ValueField)
               && !destPrograms.some(a=>a.ValueField===r.ValueField)){
                 allottedPrograms.push(r);
            }
          });
          availablePrograms=[];renderLeft(availablePrograms);renderDest();
        }

        function removeSelected(){
          var right=safeRight(); if(!right)return;
          var rows=right.getSelectedRowsData(); if(!rows.length){notify("Select items to remove","warning");return;}
          rows.forEach(r=>{
            if(allottedPrograms.some(a=>a.ValueField===r.ValueField)){
              allottedPrograms=allottedPrograms.filter(a=>a.ValueField!==r.ValueField);
              availablePrograms.push(r);
            }
          });
          renderLeft(availablePrograms);renderDest();
        }

        function removeAll(){
          if(!allottedPrograms.length){notify("No new programmes to remove","warning");return;}
          availablePrograms=availablePrograms.concat(allottedPrograms);
          allottedPrograms=[];renderLeft(availablePrograms);renderDest();
        }


        function resetSelectBox(id){ const box=DevExpress.ui.dxSelectBox.getInstance(document.getElementById(id)); if(box){ box.option({dataSource:[],value:null}); } }
         function getDxText(id, type){
          try{
            if(type==='lookup') return DevExpress.ui.dxLookup.getInstance(document.getElementById(id)).option('displayValue');
            const inst = DevExpress.ui.dxSelectBox.getInstance(document.getElementById(id));
            return inst.option('text');
          }catch(e){ return ""; }
        }
         function getDxVal(id, type){ // type: 'lookup' | 'select'
          try{
            if(type==='lookup') return DevExpress.ui.dxLookup.getInstance(document.getElementById(id)).option('value');
            return DevExpress.ui.dxSelectBox.getInstance(document.getElementById(id)).option('value');
          }catch(e){ return null; }
        }
      

           function updateAllotment(){
                          const activeTab = getActiveTab();
        if(activeTab === 'KIOSK'){
                                      var KioskID=DevExpress.ui.dxLookup.getInstance(document.getElementById("KioskID")).option("value");
               var ServiceID=DevExpress.ui.dxSelectBox.getInstance(document.getElementById("Services")).option("value");
               var CourseCategeryId= DevExpress.ui.dxSelectBox.getInstance(document.getElementById("FacultyId")).option("value");
               debugger;
               if(!KioskID||!ServiceID||!CourseCategeryId){ notify("Select Kiosk Service and  Faculty/Academy ","warning"); return;}
             // var ids=allottedPrograms.map(p=>p.ValueField);
             // ✅ Get all program IDs (already allotted + newly added)
             var ids = destPrograms.concat(allottedPrograms).map(p => p.ValueField);
               var payload={Ids:ids,KioskID:KioskID,ServiceId:ServiceID,CourseCategeryId:CourseCategeryId};
               debugger
               $.ajax({
                 url:'@Url.Action("ProgramAllotmentPost", "Admin")',
                 type:'POST',
                 data:JSON.stringify(payload),
                 contentType:"application/json; charset=utf-8",
                 success:(resp)=>{
                     notify(resp?.message ?? "Update successful","success",1000);
                     setTimeout(()=>window.location.href=resp.redirectUrl,2000);
                 },
                 error:()=>notify("Update failed","error",5000)
               });
               }
               else{
                            var ProgramId=DevExpress.ui.dxLookup.getInstance(document.getElementById("ProgrammeSelect")).option("value");
                                  var ids=allottedPrograms.map(p=>p.ValueField);
                                                var payload={Ids:ProgramId,KioskID:ids,ServiceId:0,CourseCategeryId:0};
                   debugger
                   $.ajax({
                     url:'@Url.Action("ProgramAllotmentPost", "Admin")',
                     type:'POST',
                     data:JSON.stringify(payload),
                     contentType:"application/json; charset=utf-8",
                     success:(resp)=>{
                         notify(resp?.message ?? "Update successful","success",1000);
                         setTimeout(()=>window.location.href=resp.redirectUrl,2000);
                     },
                     error:()=>notify("Update failed","error",5000)
                   });

                       }


            }

</script>
