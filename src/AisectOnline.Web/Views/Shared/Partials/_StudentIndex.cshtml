            {
                string name = (string)item.DisplayName.ToLower();
                if (name.Contains("search") || name.Contains("print") || name.Contains("admit") || name.Contains("financial"))
                {
                    string iconClass = name.Contains("search") ? "fa-magnifying-glass" : (name.Contains("print") ? "fa-print" : "fa-file-invoice");
                    <a class="menu-item" asp-controller="@item.ControllerName" asp-action="@item.ActionName">
                        <div class="icon-box"><i class="fa-solid @iconClass"></i></div>
                        <div class="menu-item-title">@item.DisplayName</div>
                    </a>
                }
            }
        </div>
    </fieldset>

    <button id="viewBtn" class="view-all-btn" onclick="toggleServices()">View All Services</button>
</div>

<script>
    function toggleServices() {
        const fieldsets = document.querySelectorAll('.hidden-fieldset');
        const btn = document.getElementById('viewBtn');
        fieldsets.forEach(fs => {
            if (fs.style.display === "block") {
                fs.style.display = "none";
                btn.innerText = "View All Services";
            } else {
                fs.style.display = "block";
                btn.innerText = "Show Less";
            }
        });
    }

    function filterServices() {
        let input = document.getElementById('serviceSearch').value.toLowerCase();
        let sections = document.querySelectorAll('.searchable-section');
        let viewBtn = document.getElementById('viewBtn');

        sections.forEach(section => {
            let items = section.querySelectorAll('.menu-item');
            let hasVisibleItem = false;

            items.forEach(item => {
                let text = item.innerText.toLowerCase();
                if (text.includes(input)) {
                    item.style.display = "flex";
                    hasVisibleItem = true;
                } else {
                    item.style.display = "none";
                }
            });

            if (input.length > 0) {
                section.style.display = hasVisibleItem ? "block" : "none";
                viewBtn.style.display = "none";
            } else {
                viewBtn.style.display = "block";
                section.style.display = section.classList.contains('hidden-fieldset') ? "none" : "block";
            }
        });
    }
</script>