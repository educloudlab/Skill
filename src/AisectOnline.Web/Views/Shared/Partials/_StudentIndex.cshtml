<div class="services-section">

    <div class="top-header">
        <h1 class="main-page-title">Student Service Portal</h1>
        <div class="search-container">
            <i class="fa-solid fa-search search-icon"></i>
            <input type="text" id="serviceSearch" class="search-input" placeholder="Search services..." onkeyup="filterServices()">
        </div>
    </div>

    <fieldset class="category-fieldset border-adm searchable-section">
        <legend class="category-legend">
            <span class="legend-content head-adm"><i class="fa-solid fa-user-graduate"></i> Admission Details</span>
        </legend>
        <div class="menu-wrapper">
            @foreach (var item in Model)
            {
                string name = (string)item.DisplayName.ToLower();
                if (name.Contains("admission") || name.Contains("registration") || name.Contains("document") || name.Contains("subject"))
                {
                    string iconClass = name.Contains("re-registration") ? "fa-arrows-rotate" : "fa-user-plus";
                    <a class="menu-item" asp-controller="@item.ControllerName" asp-action="@item.ActionName">
                        <div class="icon-box"><i class="fa-solid @iconClass"></i></div>
                        <div class="menu-item-title">@item.DisplayName</div>
                    </a>
                }
            }
        </div>
    </fieldset>

    <fieldset class="category-fieldset border-exm searchable-section">
        <legend class="category-legend">
            <span class="legend-content head-exm"><i class="fa-solid fa-file-invoice"></i> Exam Details</span>
        </legend>
        <div class="menu-wrapper">
            @foreach (var item in Model)
            {
                string name = (string)item.DisplayName.ToLower();
                if (name.Contains("assign") || (name.Contains("exam") && !name.Contains("fee")))
                {
                    <a class="menu-item" asp-controller="@item.ControllerName" asp-action="@item.ActionName">
                        <div class="icon-box"><i class="fa-solid fa-file-pen"></i></div>
                        <div class="menu-item-title">@item.DisplayName</div>
                    </a>
                }
            }
        </div>
    </fieldset>

    <fieldset class="category-fieldset border-fee hidden-fieldset searchable-section">
        <legend class="category-legend">
            <span class="legend-content head-fee"><i class="fa-solid fa-credit-card"></i> Fees Details</span>
        </legend>
        <div class="menu-wrapper">
            @foreach (var item in Model)
            {
                string name = (string)item.DisplayName.ToLower();
                if (name.Contains("fee") || name.Contains("payment"))
                {
                    <a class="menu-item" asp-controller="@item.ControllerName" asp-action="@item.ActionName">
                        <div class="icon-box"><i class="fa-solid fa-wallet"></i></div>
                        <div class="menu-item-title">@item.DisplayName</div>
                    </a>
                }
            }
        </div>
    </fieldset>

    <fieldset class="category-fieldset border-sch hidden-fieldset searchable-section">
        <legend class="category-legend">
            <span class="legend-content head-sch"><i class="fa-solid fa-magnifying-glass"></i> Search Portal</span>
        </legend>
        <div class="menu-wrapper">
            @foreach (var item in Model)
            {
                string name = (string)item.DisplayName.ToLower();
                if (name.Contains("search") || name.Contains("print") || name.Contains("admit") || name.Contains("financial"))
                {
                    string iconClass = name.Contains("search") ? "fa-magnifying-glass" : (name.Contains("print") ? "fa-print" : "fa-file-invoice");
                    <a class="menu-item" asp-controller="@item.ControllerName" asp-action="@item.ActionName">
                        <div class="icon-box"><i class="fa-solid @iconClass"></i></div>
                        <div class="menu-item-title">@item.DisplayName</div>
                    </a>
                }
            }
        </div>
    </fieldset>

    <button id="viewBtn" class="view-all-btn" onclick="toggleServices()">View All Services</button>
</div>

<script>
    function toggleServices() {
        const fieldsets = document.querySelectorAll('.hidden-fieldset');
        const btn = document.getElementById('viewBtn');
        fieldsets.forEach(fs => {
            if (fs.style.display === "block") {
                fs.style.display = "none";
                btn.innerText = "View All Services";
            } else {
                fs.style.display = "block";
                btn.innerText = "Show Less";
            }
        });
    }

    function filterServices() {
        let input = document.getElementById('serviceSearch').value.toLowerCase();
        let sections = document.querySelectorAll('.searchable-section');
        let viewBtn = document.getElementById('viewBtn');

        sections.forEach(section => {
            let items = section.querySelectorAll('.menu-item');
            let hasVisibleItem = false;

            items.forEach(item => {
                let text = item.innerText.toLowerCase();
                if (text.includes(input)) {
                    item.style.display = "flex";
                    hasVisibleItem = true;
                } else {
                    item.style.display = "none";
                }
            });

            if (input.length > 0) {
                section.style.display = hasVisibleItem ? "block" : "none";
                viewBtn.style.display = "none";
            } else {
                viewBtn.style.display = "block";
                section.style.display = section.classList.contains('hidden-fieldset') ? "none" : "block";
            }
        });
    }
</script> *@


