    /* Shapes */
    .tracker-shape {
        position: absolute;
    }

        .tracker-shape.triangle {
            width: 0;
            height: 0;
            border-left: 60px solid transparent;
            border-right: 60px solid transparent;
            border-bottom: 100px solid rgba(0,0,255,0.3);
            top: 50px;
            right: 100px;
        }

        .tracker-shape.ball {
            width: 20px;
