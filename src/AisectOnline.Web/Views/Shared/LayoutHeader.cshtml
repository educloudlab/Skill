        </style>

        
<script>
let angle = 0;
let scale = 1;
let growing = true;

function animate() {
  angle += 0.5;
  
  // Circle pulsing
  const big = document.querySelector('.tracker-circle.big');
  const small = document.querySelector('.tracker-circle.small');
  
  if (growing) {
    scale += 0.002;
    if (scale > 1.05) growing = false;
  } else {
    scale -= 0.002;
    if (scale < 0.95) growing = true;
  }
  
  big.style.transform = `scale(${scale})`;
  small.style.transform = `scale(${1 + (scale - 1) / 2})`;
  
  // Floating triangle
  const triangle = document.querySelector('.tracker-shape.triangle');
  triangle.style.transform = `translateY(${Math.sin(angle / 20) * 15}px) rotate(${Math.sin(angle / 40) * 10}deg)`;
  
  // Floating ball
  const ball = document.querySelector('.tracker-shape.ball');
  ball.style.transform = `translateY(${Math.cos(angle / 20) * 20}px)`;
  
  requestAnimationFrame(animate);
}

animate();
</script>