    .remove-file { margin-left: 12px; color: #c33; cursor: pointer; font-size: 19px; }
    .pdf-thumb {
      width: 42px; height: 55px; object-fit: contain; margin-right: 10px;
      border: 1px solid #bbb; border-radius: 4px; background: #fafafa; cursor: pointer;
    }
    .progress-bar-container {
      background: #eee;
      border-radius: 6px;
      width: 185px;
      height: 7px;
      overflow: hidden;
      margin-bottom: 8px;
      position: relative;
    }
    .progress-bar-fill {
      height: 100%;
      width: 0;
      background-color: #4abd5d;
      transition: width 0.3s cubic-bezier(.65,.05,.36,1);
    }
    .progress-count {
      font-size: 14px;
      color: #444;
      margin-top: 4px;
      font-weight: 600;
      user-select: none;
    }
    .pdf-popup-backdrop {position: fixed; left:0; top:0; right:0; bottom:0; background: rgba(0,0,0,0.28); z-index: 60;}
    .pdf-popup {
      position: fixed; left: 50%; top: 50%; transform: translate(-50%, -50%);
      background: #fff; border-radius: 8px; box-shadow: 0 4px 48px #2227; z-index: 61; padding: 18px 20px;
    }
    .pdf-popup embed { border-radius: 5px; }
    .popup-close { cursor: pointer; color: #c33; position: absolute; right: 14px; top: 11px; font-size: 24px; }
   
