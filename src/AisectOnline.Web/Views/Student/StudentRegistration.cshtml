                        function loadCourseFeeDetail() {
                const valCourseFeeID = DevExpress.ui.dxSelectBox.getInstance(document.getElementById("CourseFeeID"))?.option("value") || 0;
                const valSessionID = DevExpress.ui.dxSelectBox.getInstance(document.getElementById("Session"))?.option("value") || 0;
                const valStudentID = DevExpress.ui.dxSelectBox.getInstance(document.getElementById("StudentID"))?.option("value") || 0;
                const valKioskID = '@Model.Kioskid';

                if (!valStudentID || valStudentID === 0) {
                    alert("Please select a valid student.");
                    return;
                }

                const url1 = '@Url.Action("FillCourseFeeDetail1", "Student")';

                $.ajaxSetup({ cache: false });

                $.getJSON(url1, {
                    valCourseFeeID,
                    valSessionID,
                    valStudentID,
                    valKioskID
                }, function (data) {
                    clearDynamicTable(); // Clears the table before refill
                    createDynamicTable($("#regFeeDetail"), data); // Builds new rows
                    document.getElementById('mgrDiv').style.display = "block";
                }).fail(function (jqXHR, textStatus, errorThrown) {
                    console.error("AJAX Error:", textStatus, errorThrown);
                    alert("Failed to load course fee detail.");
                });
            }

// 🏠 Copy address when checkbox is checked
 function copyAddressFunc() {
        const isChecked = document.getElementById("copyAddress").checked;

        // Correspondence fields instances
        const corresAddress = $("#CorresAddress").dxTextArea("instance");
        const corresVillage = $("#CorresVillageTownCity").dxTextBox("instance");
        const corresState = $("#CorresState").dxSelectBox("instance");
        const corresPin = $("#CorresPin").dxTextBox("instance");
        const corresDistrict = $("#CorresDistrict").dxSelectBox("instance");

        if (isChecked) {
            // Copy values from Permanent address
            corresAddress.option("value", $("#ContactAddress").dxTextArea("instance").option("value"));
            corresVillage.option("value", $("#VillageTownCity").dxTextBox("instance").option("value"));
            corresState.option("value", $("#State").dxSelectBox("instance").option("value"));
            corresPin.option("value", $("#Pin").dxTextBox("instance").option("value"));
            corresDistrict.option("value", $("#District").dxSelectBox("instance").option("value"));

            // Disable fields
            corresAddress.option("disabled", true);
            corresVillage.option("disabled", true);
            corresState.option("disabled", true);
            corresPin.option("disabled", true);
            corresDistrict.option("disabled", true);
        } else {
            // Clear fields
            corresAddress.option("value", "");
            corresVillage.option("value", "");
            corresState.option("value", null);
            corresPin.option("value", "");
            corresDistrict.option("value", null);

            // Enable fields
            corresAddress.option("disabled", false);
            corresVillage.option("disabled", false);
            corresState.option("disabled", false);
            corresPin.option("disabled", false);
            corresDistrict.option("disabled", false);
        }
    }

    // Bind checkbox change
    document.getElementById("copyAddress").addEventListener("change", copyAddressFunc);




                    //image upload
                   function ShowImageValidationAndUpload(e) {
                    const file = e.value[0];
                    if (!file) return;

                    const allowedExtensions = ['jpg', 'jpeg', 'png'];
                    const fileExt = file.name.split('.').pop().toLowerCase();
                    const fileSizeKB = file.size / 200;

                    if (!allowedExtensions.includes(fileExt)) {
                        DevExpress.ui.notify("Only image files (jpg, png, gif) are allowed!", "error", 2000);
                        e.component.reset();
                        return;
                    }

                    if (fileSizeKB > 200) {
                        DevExpress.ui.notify("Image size must be less than 1MB", "error", 2000);
                        e.component.reset();
                        return;
                    }

                    // Show image preview
                    const reader = new FileReader();
                    reader.onload = function (evt) {
                        document.getElementById("profilePreview").src = evt.target.result;
                    };
                    reader.readAsDataURL(file);
                }


