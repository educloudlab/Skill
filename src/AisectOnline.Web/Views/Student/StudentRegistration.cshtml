@model AisectOnline.Services.Modules.Students.StudentDto
@using AisectOnline.Services.Modules.Students
@using DevExtreme.AspNet.Mvc
@{
    Layout = "_Layout";
}

<body class="custom-global-style custom-background">
    <div class="custom-background" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: inherit; z-index: -1; backdrop-filter: blur(6px);"></div>

    <div class="form-container">
        <div id="dxTabs"></div>
             <form id="studentForm" action="/Student/StudentRegistration2" method="post" enctype="multipart/form-data">

         @Html.Hidden("KioskTypeID", @Model?.KioskTypeID, new { id = "KioskTypeID" })

                    @Html.Hidden("ServiceId", @Model?.ServiceId, new { id = "ServiceId" })
                    @Html.Hidden("BranchManager", @Model?.BranchManager, new { id = "BranchManager" })
                    @Html.Hidden("RequestNo", @Model?.RequestNo, new { id = "RequestNo" })
                    @Html.Hidden("Kioskid", @Model?.Kioskid, new { id = "Kioskid" })
        <div class="form-section show animate">
            <div style="background: #bdebb980; padding: 10px; text-align: center; font-size: 18px; font-weight: 500; color: #1a237e; border-bottom: 1px solid #ddd; margin-bottom: 20px;     margin-top: -20px;
}">
                Kiosk Type and Services
            </div>
            <div class="form-row">

                <div class="form-group">
                    <label for="tel" class="col-form-label">
                        Session
                        <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().SelectBox().ID("Session").Name("Session").DataSource(Model.SessionDropdown).DisplayExpr("TextField").ValueExpr("ValueField").Value(Model.Session).Placeholder("Please Select").InputAttr("aria-label", "Session")   .ValidationRules(rules => {
                        rules.AddRequired().Message("Session is required.");
                    }) .OnValueChanged("function(e) { copy(e); }")
                     )
                </div>
                <div class="form-group">
                    <label for="select" class="col-form-label">
                        Faculty/Academy
                        <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().SelectBox().ID("CourseCategory").Name("CourseCategory").DataSource(Model.CourseCategoryDropdown).DisplayExpr("TextField").ValueExpr("ValueField").Value(Model.CourseCategory).Placeholder("Please Select").InputAttr("aria-label", "CourseCategory") .ValidationRules(rules => {
                        rules.AddRequired().Message("Faculty/Academy is required.");
                    }) .OnValueChanged("function(e) { onCourseCategoryChanged(e); }")
                     )
                </div>
                <div class="form-group">
                    <label for="select" class="col-form-label">
                        Program Name
                        <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().SelectBox().ID("Program").Name("Program").DataSource(Model.ProgramDropdown).DisplayExpr("TextField").ValueExpr("ValueField").Placeholder("Please Select").Value(Model.Program).InputAttr("aria-label", "Program") .ValidationRules(rules => {
                        rules.AddRequired().Message("Program Name is required.");
                    }) .OnValueChanged("function(e) { onProgramChanged(e); }")
                     )

                </div>
                <div class="form-group">
                    <label for="tel" class="col-form-label">
                        University/Scheme
                        <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().SelectBox().ID("Scheme").Name("Scheme").DataSource(Model.SchemeDropdown).DisplayExpr("TextField").ValueExpr("ValueField").Placeholder("Please Select").Value(Model.Scheme).InputAttr("aria-label", "Scheme") .ValidationRules(rules => {
                        rules.AddRequired().Message("University/Scheme is required.");
                    }) .OnValueChanged("function(e) { onSchemeChanged(e); }")
                     )
                </div>
                <div class="form-group">
                    <label for="ctype" class="col-form-label">
                        Course/Years
                        <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().SelectBox().ID("CourseFeeID").Name("CourseFeeID").DataSource(Model.CourseFeeIDDropdown).DisplayExpr("TextField").ValueExpr("ValueField").Placeholder("Please Select").Value(Model.CourseFeeID).InputAttr("aria-label", "CourseFeeID")  .ValidationRules(rules => {
                        rules.AddRequired().Message("Course/Years is required.");
                    })  .OnValueChanged("onCourseFeeChange")
                     )


                </div>
                <div class="form-group">
                    <label for="coursemed" class="col-form-label">Preferd Course Medium<span class="asteriskField" style="color: red">*</span></label>
                    @(Html.DevExtreme().SelectBox().ID("CourseMedium1").Name("CourseMedium1").DataSource(Model.CourseMediumDropdown).DisplayExpr("TextField").ValueExpr("ValueField").Value(Model.CourseMedium1).Placeholder("Please Select").InputAttr("aria-label", "CourseMedium1") .ValidationRules(rules => {
                        rules.AddRequired().Message("Preferred Course Medium is required.");
                    })  .OnValueChanged("onMediumChanged")
                     )
                </div>
                <div class="form-group col-md-12">

                    <div class="main-containern">

                        <fieldset class="info-section">
                            <legend style="
                                background: #f9f9f9;
                                width: 24%;
                                font-size: 13px;
                                font-weight: bold;
                                color: #7b00b1;">
                                Optional Subject
                            </legend>
                            <div class="fees-row">
                                <span style="color: Red" id="validChk"></span>
                                <div id="optionalSubjectsContainer">

                                    <!-- Checkboxes will render here -->
                                </div>

                            </div>
                        </fieldset>
                        <fieldset class="info-section">
                            <legend style="
                                background: #f9f9f9;
                                width: 55%;
                                font-size: 13px;
                                font-weight: bold;
                                color: #7b00b1;">
                                Fees Details
                            </legend>
                            <div class="fees-row">
                                <table id="regFeeDetail" class="custom-table">
                                    <!-- Dynamic fee rows should go here -->
                                </table>

                            </div>
                        </fieldset>

                        <fieldset class="photo-section">
                            <legend style="
                                background: #f9f9f9;
                                width: 55%;
                                font-size: 13px;
                                font-weight: bold;
                                color: #7b00b1;">
                                Upload Photo*
                            </legend>
                            <div class="upload-box" id="preview-box">
                                <img id="profilePreview"
                                     src="~/Images/Profile.jpg"
                                     alt="Profile Preview"
                                     style="width: 100px; height: 121px;  border: 1px solid #ccc;" />
                            </div>
                            <div class="note">Photograph is<br>mandatory</div>
                            <div class="file-center">
                                <input type="hidden" name="PhotoValid" id="PhotoValid" value="false">
                                @(Html.DevExtreme().FileUploader()
                                                                .Name("Photo")
                                                                .ID("photoUploader")
                                                                .SelectButtonText("Select photo")
                                                                .LabelText("")
                                                                .Accept("image/*")
                                                                .UploadMode(FileUploadMode.UseForm)
                                                                .InputAttr("aria-label", "Select Photo")
                                                                .OnValueChanged("validateImage")
                                                                .ShowFileList(false)
                                                                 )
                            </div>
                        </fieldset>
                    </div>

                </div>
            </div>
               <div class="submit-btn">
<button class="next-button" type="button" onclick="nextTab()">NEXT</button>      
</div>
        </div>

        <div class="form-section">
            <div style="background:#ffadcf59; padding: 10px; text-align: center; font-size: 18px; font-weight: 500; color: #1a237e; border-bottom: 1px solid #ddd; margin-bottom: 20px;     margin-top: -20px;
}">
                Personal Information
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="FirstName" class="col-form-label">
                        First Name <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().TextBox().ID("FirstName").Name("FirstName").Value(Model?.FirstName).MaxLength(50)
                                        .InputAttr("aria-label", "First Name")
                                        .Placeholder("Enter First Name")  .ValidationRules(rules => {
                        rules.AddRequired().Message("First Name is required.");
                    })
                     )
                </div>
                <div class="form-group">
                    <label for="LastName" class="col-form-label">
                        Last Name <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().TextBox()
                                        .ID("LastName")
                                        .Name("LastName")
                                        .Value(Model?.LastName)
                                        .MaxLength(50)
                                        .InputAttr("aria-label", "Last Name")
                                         .ValidationRules(rules => {
                        rules.AddRequired().Message("Last Name is required.");
                    })
                                        .Placeholder("Enter Last Name")
                                         )
                </div>
                <div class="form-group">
                    <label for="Dob" class="col-form-label">
                        Father's/Husband's Name <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().TextBox().ID("FatherName").Name("FatherName").Value(Model?.FatherName).MaxLength(50).InputAttr("aria-label", "Father Name").Placeholder("Enter Father Name")  .ValidationRules(rules => {
                        rules.AddRequired().Message("Father's/Husband's Name is required.");
                    })
                     )

                </div>
            </div>


            <div class="form-row">
                <div class="form-group">
                    <label for="MotherName" class="col-form-label">
                        Mother's Name <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().TextBox()
                                        .ID("MotherName")
                                        .Name("MotherName")
                                        .Value(Model?.MotherName)
                                        .MaxLength(50)
                                        .Placeholder("Enter Mother Name") .ValidationRules(rules => {
                        rules.AddRequired().Message("Mother's Name is required.");
                    })
                     )
                </div>

                <div class="form-group">
                    <label for="select" class="col-form-label">
                        Date of Birth
                        <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().DateBox().ID("Dob").Name("Dob").Value((DateTime?)Model?.Dob).Type(DateBoxType.Date).DisplayFormat("yyyy-MM-dd")   .ValidationRules(rules => {
                        rules.AddRequired().Message("Date of Birth is required.");
                    })
                     )
                </div>
                <div class="form-group">
                    <label for="select" class="col-form-label">
                        Email
                        <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().TextBox().ID("EmailAddress").Name("EmailAddress").Value(Model?.EmailAddress).Mode(TextBoxMode.Email).MaxLength(50).InputAttr(new { onkeypress = "return RestrictCommaSemicolon(event);", ondrop = "return false;" }).Placeholder("Enter Email ") .ValidationRules(rules => {
                        rules.AddRequired().Message("Email is required.");
                    })
                     )
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="select" class="col-form-label">
                        Mobile No
                        <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().TextBox().ID("MobileNo").Name("MobileNo").Value(Model?.MobileNo).Mode(TextBoxMode.Text).MaxLength(50).MaxLength(12).InputAttr("aria-label", "Mobile No").Placeholder("Enter MobileNo") .ValidationRules(rules => {
                        rules.AddRequired().Message("Mobile No is required.");
                    })
                     )

                </div>
                <div class="form-group">
                    <label for="select" class="col-form-label">
                                                                                            marital  Status                           <span class="asteriskField" style="color: red">*</span>

                    </label>
                                                                                   @(Html.DevExtreme().SelectBox().ID("MaritalStatus").Name("MaritalStatus").DataSource(Model.MaritalStatusDropdown).DisplayExpr("TextField").ValueExpr("ValueField").Value(Model?.MaritalStatus).Placeholder("Please Select").InputAttr("aria-label", "MaritalStatus")  .ValidationRules(rules => {
                        rules.AddRequired().Message("marital Status is required.");
                    })
                                                                                    )

                </div>
                <div class="form-group">
                    <label for="select" class="col-form-label">
                        Gender
                        <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().SelectBox().ID("Sex").Name("Sex").DataSource(Model.SexDropdown).DisplayExpr("TextField").ValueExpr("ValueField").Value(Model?.Sex).Placeholder("Please Select").InputAttr("aria-label", "Sex")  .ValidationRules(rules => {
                        rules.AddRequired().Message("Gender is required.");
                    })
                     )
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="select" class="col-form-label">
                        Category                           <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().SelectBox().ID("Category").Name("Category").DataSource(Model.CategoryDropdown).DisplayExpr("TextField").ValueExpr("ValueField").Value(Model?.Category).Placeholder("Please Select").InputAttr("aria-label", "Category") .ValidationRules(rules => {
                        rules.AddRequired().Message("Category is required.");
                    })
                     )


                </div>
                <div class="form-group">
                    <label for="select" class="col-form-label">
                        Driving Licence Type                        <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().SelectBox().ID("DrivingLicenceType").Name("DrivingLicenceType").DataSource(Model.DrivingLicenceTypeDropdown).DisplayExpr("TextField").ValueExpr("ValueField").Value(Model?.DrivingLicenceType).Placeholder("Please Select").InputAttr("aria-label", "DrivingLicenceType") .ValidationRules(rules => {
                        rules.AddRequired().Message("Driving Licence Type is required.");
                    })
                     )

                </div>
                <div class="form-group">
                    <label for="select" class="col-form-label">
                        Adhar Number
                        <span class="asteriskField" style="color: red">*</span>
                    </label>
                    <div class="form-group">

                        @(Html.DevExtreme().TextBox().ID("AadharNo").Name("AadharNo").Value(Model?.AadharNo).MaxLength(12) .ValidationRules(rules => {
                        rules.AddRequired().Message("Aadhar Number is required.");
                    })
                         )
                    </div>





                </div>



            </div>

            <div class="form-row">
                <div class="form-group">

                    <div class="col-md-12">

                        <legend>Permanent Address<small> (As per attached document)</small></legend>

                        <div class="form-row">
                            <div class="form-group">
                                <label id="padd" for="name">Parmanant Address</label>
                                @(Html.DevExtreme().TextArea()
                                                                .ID("ContactAddress")
                                                                .Name("ContactAddress")
                                                                .Value(Model?.ContactAddress)
                                                                .Height(124)
                                                                .MaxLength(200)
                                                                .InputAttr("style", "resize:none;width:100%")
                                                                .OnInput("function(e) { if (e.event.keyCode === 13) e.event.preventDefault(); }")  .ValidationRules(rules => {
                                rules.AddRequired().Message("Permanent Address is required.");
                            })
                             )
                            </div>
                            <div class="form-group">
                                <label id="state" for="name">City</label>
                                @(Html.DevExtreme().TextBox()
                                                                .ID("VillageTownCity")
                                                                .Name("VillageTownCity")
                                                                .Value(Model?.VillageTownCity)
                                                                .MaxLength(50)  .ValidationRules(rules => {
                                rules.AddRequired().Message("City is required.");
                            })
                             )    
                                                                
                                                                <div class="form-group" style="    margin-top: 4%;">
                                    <label id="name-label13" for="name">State</label>
                                    @(Html.DevExtreme().SelectBox()
                                                                        .ID("State")
                                                                        .Name("State")
                                                                        .DataSource(Model.StateDropdown)
                                                                        .DisplayExpr("TextField")
                                                                        .ValueExpr("ValueField")
                                                                        .Value(Model?.State)
                                                                        .Placeholder("Please Select")
                                                                        .InputAttr("aria-label", "State")
                                                                        .OnValueChanged("function(e) { onStateChanged(e,'per'); }") .ValidationRules(rules => {
                                rules.AddRequired().Message("State is required.");
                            })
                             )
                                </div>
                            </div>
                            <div class="form-group">
                                <label id="pin" for="number">Pin Code</label>
                                @(Html.DevExtreme().TextBox()
                                                                .ID("Pin")
                                                                .Name("Pin")
                                                                .Value(Model?.Pin)
                                                                .MaxLength(6)  .ValidationRules(rules => {
                                rules.AddRequired().Message("Pin Code is required.");
                            }))                                <div class="form-group" style="    margin-top: 4%;">
                                    <label id="dist" for="number">District</label>
    @(Html.DevExtreme().SelectBox()
                    .ID("District")
                    .Name("District")
                    .DataSource(Model.DistrictDropdown)
                    .DisplayExpr("displayExpr")
                    .ValueExpr("valueExpr")
                    .Value(Model?.District)
                    .Placeholder("Please Select")
                    .InputAttr("aria-label", "District")
                    .ValidationRules(rules => {
                        rules.AddRequired().Message("District is required.");
                    })
                     )
                                </div>
                            </div>


                        </div>
                    </div>




                </div>

            </div>
         
                <div class="form-group">

                    <div class="col-md-12">
                        <div class="form-check">
     <legend>
                            Correspondance Address<small> (Same as Permananent Address)</small>
<input type="checkbox" class="form-check-input" id="copyAddress" onclick="copyAddressFunc()" style="width:1%;cursor: auto;">
                </legend>
</div>
                      
                        <div class="form-row">
                            <div class="form-group">
                                <label id="name-label15" for="name">Correspondance Address</label>
  @(Html.DevExtreme().TextArea()
                    .ID("CorresAddress")
                    .Name("CorresAddress")
                    .Value(Model?.CorresAddress)
                    .Height(124)
                    .MaxLength(200)
                    .InputAttr("style", "resize:none;width:100%"))
                            </div>
                            <div class="form-group">
                                <label id="state" for="name">City</label>
   @(Html.DevExtreme().TextBox()
                    .ID("CorresVillageTownCity")
                    .Name("CorresVillageTownCity")
                    .Value(Model?.CorresVillageTownCity)
                    .MaxLength(50)
    )
                                <div class="form-group" style="    margin-top: 4%;">
                                    <label id="name-label13" for="name">State</label>
 @(Html.DevExtreme().SelectBox()
                    .ID("CorresState")
                    .Name("CorresState")
                    .DataSource(Model.StateDropdown)
                    .DisplayExpr("TextField")
                    .ValueExpr("ValueField")
                    .Value(Model?.CorresState )
                    .Placeholder("Please Select")
                    .InputAttr("aria-label", "State")
                    .OnValueChanged("function(e) { onStateChanged(e,'cor'); }")
  )

                                </div>
                            </div>
                            <div class="form-group">
                                <label id="pin" for="number">Pin Code</label>
 @(Html.DevExtreme().TextBox()
                    .ID("CorresPin")
                    .Name("CorresPin")
                    .Value(Model?.CorresPin)
                    .MaxLength(6)
  )

                                <div class="form-group" style="    margin-top: 4%;">
                                    <label id="dist" for="number">District</label>
                                    @(Html.DevExtreme().SelectBox()
                    .ID("CorresDistrict")
                    .Name("CorresDistrict")
                    .DataSource(Model.CorresDistrictDropdown)
                    .DisplayExpr("displayExpr")
                    .ValueExpr("valueExpr")
                    .Value(Model?.CorresDistrict)
                    .Placeholder("Please Select")
                    .InputAttr("aria-label", "District")
                                     )

                                </div>
                            </div>


                        </div>
                    </div>




                </div>

   
   <div class="submit-btn">
<button class="next-button" type="button" onclick="nextTab()">NEXT</button>      
</div>



        </div>
        <div class="form-section">
            <div style="background: #bcddff5c; padding: 10px; text-align: center; font-size: 18px; font-weight: 500; color: #1a237e; border-bottom: 1px solid #ddd; margin-bottom: 20px;     margin-top: -20px;
}">
                Education And Others
            </div>
            <div class="col-md-12">

                <legend>Education</legend>

            </div>
            <div class="form-row">
                <div class="form-group">
                    <label id="aqualification" for="aquli">
                        Academic Qualification
                        <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().SelectBox().ID("AcademicQualification").Name("AcademicQualification").DataSource(Model.AcademicQualificationDropdown).DisplayExpr("TextField").ValueExpr("ValueField").Value(Model?.AcademicQualification).Placeholder("Please Select").InputAttr("aria-label", "AcademicQualification")   .ValidationRules(rules => {
                        rules.AddRequired().Message("Academic Qualification is required.");
                    })
                     )

                </div>

                <div class="form-group">
                    <label id="msub" for="msub">
                        Main Subject
                    </label>
                    @(Html.DevExtreme().TextBox().ID("MainSubject").Name("MainSubject").Value(Model?.MainSubject).MaxLength(50).InputAttr("aria-label", "Main Subject").Placeholder("Enter Main Subject") )
                </div>
                <div class="form-group">
                    <label id="yop" for="name">
                        Year Of Passing
                    </label>
                    @(Html.DevExtreme().NumberBox().ID("YearOfPassing").Name("YearOfPassing").Value(Model?.YearOfPassing).Min(2000).Max(DateTime.Now.Year).InputAttr("aria-label", "YearOfPassing").Placeholder("Enter Year of Passing") )

                </div>
                <div class="form-group">
                    <label id="division" for="div">
                        Division
                    </label>
                    @(Html.DevExtreme().TextBox().ID("Division").Name("Division").Value(Model?.Division).InputAttr("aria-label", "Division").Placeholder("Enter Division") )
                </div>
                <div class="form-group">
                    <label id="perc" for="name">
                        % of Marks
                    </label>
                    @(Html.DevExtreme().NumberBox()
                                        .ID("MarksPercentage")
                                        .Name("MarksPercentage")
                                        .Value((double?)Model?.MarksPercentage)  // 👈 Cast to double?
                                        .Min(0)
                                        .Max(100)
                                        .Step(0.01)
                                        .Format("#0.##")
                                        .Placeholder("Enter Marks Percentage")
                                         )
                </div>


                <div class="form-group">
                    <label id="board" for="name">
                        Board
                    </label>
                    @(Html.DevExtreme().TextBox()
                                        .ID("BoardCode")
                                        .Name("BoardCode")
                                        .Value(Model?.BoardCode)
                                        .MaxLength(50)
                                        .InputAttr("aria-label", "Board Code")
                                        .Placeholder("Enter Board Code")
                                         
                                        )
                </div>

                <div class="form-group">
                    <label id="emedium" for="emedium">
                        Course Medium                                                                                <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().SelectBox().ID("CourseMedium").Name("CourseMedium").DataSource(Model.CourseMediumDropdown).DisplayExpr("TextField").ValueExpr("ValueField").Value(Model?.CourseMedium).Placeholder("Please Select").InputAttr("aria-label", "CourseMedium") .ValidationRules(rules => {
                        rules.AddRequired().Message("Course Medium is required.");
                    })
                     )


                </div>
                <div class="form-group">
                    <label id="deb" for="deb">
                        DEB Id
                    </label>
                    @(Html.DevExtreme().TextBox().ID("Deb").Name("Deb").Value(Model?.Deb).MaxLength(50).InputAttr("aria-label", "Deb").Placeholder("Enter DEB ID") )
                </div>
                <div class="form-group">
                    <label id="belong" for="belong">
                        Belongs To                                                                               <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().SelectBox().ID("StudentBelongsTo").Name("StudentBelongsTo").DataSource(Model.StudentBelongsToDropdown).DisplayExpr("TextField").ValueExpr("ValueField").Value(Model?.StudentBelongsTo).Placeholder("Please Select").InputAttr("aria-label", "StudentBelongsTo")  .ValidationRules(rules => {
                        rules.AddRequired().Message("Belongs To is required.");
                    }) )


                </div>
            </div>

            <div class="form-row">


                <div class="form-group">
                    <label id="nation" for="nation">
                        Nationality                                                                           <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().SelectBox().ID("Nationality").Name("Nationality").DataSource(Model.NationalityDropdown).DisplayExpr("TextField").ValueExpr("ValueField").Value(Model?.Nationality).Placeholder("Please Select").InputAttr("aria-label", "Nationality")  .ValidationRules(rules => {
                        rules.AddRequired().Message("Nationality is required.");
                    }) )


                </div>
                <div class="form-group">
                    <label id="fincome" for="fincome">
                        Family Income

                        <span class="asteriskField" style="color: red">*</span>
                    </label>
                    @(Html.DevExtreme().NumberBox()
                                        .ID("FamilyIncomeYearly")
                                        .Name("FamilyIncomeYearly")
                                        .Value((double?)Model?.FamilyIncomeYearly)
                                        .Min(2000)
                                        .Max(DateTime.Now.Year)
                                        .InputAttr("aria-label", "FamilyIncomeYearly")
                                        .Placeholder("Enter Family Income Yearly") .ValidationRules(rules => {
                        rules.AddRequired().Message("Family Income is required.");
                    }) )

                </div>

                <div class="form-group">
                      @(Html.DevExtreme().Button()
        .Text("Submit")
        .Type(ButtonType.Default)
        .UseSubmitBehavior(true) 
        .StylingMode(ButtonStylingMode.Contained)
         
    )
                </div>



            </div>

            
     <div class="submit-btn">
            

            @* <button class="next-button" type="button" onclick="nextTab()">NEXT</button>    *@   
     </div>
        </div>
        </form>
