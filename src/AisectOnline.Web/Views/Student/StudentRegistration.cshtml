<script>
              function onMediumChanged(e) {
  const mediumId = e.value;
  if (mediumId != null) {
    const courseFeeId = DevExpress.ui.dxSelectBox.getInstance(document.getElementById("CourseFeeID")).option("value");
    if (!mediumId || !courseFeeId) return;

    $.ajax({
      url: '/Student/GetOptionalSubject',
      type: 'GET',
      data: {
        courseFeeId: courseFeeId,
        mediumId: mediumId
      },
      dataType: 'json',
      success: function (data1) {
        const container = $('#optionalSubjectsContainer');
        container.empty();

        const data = data1.data;
        if (!Array.isArray(data) || data.length === 0) {
          container.append('<tr><td colspan="4">No optional subjects found.</td></tr>');
          return;
        }

        let tableHTML = '';
        let rowOpen = false;

        for (let i = 0; i < data.length; i++) {
          if (i % 4 === 0) {
            if (rowOpen) tableHTML += '</tr>';
            tableHTML += '<tr>';
            rowOpen = true;
          }

          tableHTML += `
            <td>
              <label class="checkbox-label">
                <input type="checkbox" name="chkbox" id="checkbox${i}" value="${data[i].ValueField}">
                <span>${data[i].TextField}</span>
              </label>
            </td>
          `;
        }

        if (rowOpen) {
          // Fill empty <td> if total items not multiple of 4
          const remaining = 4 - (data.length % 4);
          if (remaining < 4) {
            for (let j = 0; j < remaining; j++) {
              tableHTML += `<td></td>`;
            }
          }
          tableHTML += '</tr>';
        }

        container.html(tableHTML);
        document.getElementById("chkboxcount").value = data.length;
      },
      error: function (xhr, status, error) {
        console.error("Error loading optional subjects:", error);
        alert('Failed to load optional subjects.');
      }
    });
  } else {
    $('#optionalSubjectsContainer').empty();
  }
}


                     async function onCourseFeeChange(e) {
                    const valCourseFeeID = e.value;
                    const valSessionID =  DevExpress.ui.dxSelectBox.getInstance(document.getElementById("Session")).option("value");  // Replace with actual input ID or value
                    const valStudentID = $('#StudentID').val();  // Replace with actual input ID or value
                    const kioskId = '@Model.Kioskid'; // Replace with actual kioskId or fetch dynamically

                    try {
                        const response = await fetch(`/Student/GetFees?valCourseFeeID=${valCourseFeeID}&valSessionID=${valSessionID}&valStudentID=${valStudentID}&kioskId=${kioskId}`);
                       debugger;
                        const result = await response.json();

                        if (result.success && result.data.length > 0) {
                            populateFeeTable(result.data);
                        } else {
                            $('#regFeeDetail').html('<tr><td colspan="5" class="text-center text-danger">No fee details found.</td></tr>');
                        }
                    } catch (error) {
                        console.error('Error fetching fee details:', error);

                    }
                       DevExpress.ui.dxSelectBox.getInstance(document.getElementById("CourseMedium1")).option("value", null);
                }

                function populateFeeTable(data) {
                    const table = document.getElementById("regFeeDetail");
                    table.innerHTML = ""; // Clear existing rows

                    // Add header
                    const header = `<tr>
                        <th>Fee Type</th>
                        <th>Amount</th>

                    </tr>`;
                    table.insertAdjacentHTML('beforeend', header);

                    // Populate rows
                    data.forEach(item => {
                        debugger
                        const row = `<tr>
                          <td>${item.FeeType || ''}</td>

                            <td>${item.Fee ?? 0 }</td>
                        </tr>`;
                        table.insertAdjacentHTML('beforeend', row);
                    });
                }
                   function validateImage(e) {
                    const file = e.value[0];

                    if (!file) {
                        DevExpress.ui.notify("No file selected.", "error", 2000);
                        document.getElementById("PhotoValid").value = "false";
                        return;
                    }

                    const allowedExtensions = ['png', 'jpg', 'jpeg'];
                    const fileExtension = file.name.split('.').pop().toLowerCase();
                    const fileSizeKB = file.size / 1024;

                    if (!allowedExtensions.includes(fileExtension)) {
                        DevExpress.ui.notify("Only .png, .jpg, and .jpeg files are allowed.", "error", 3000);
                        document.getElementById("PhotoValid").value = "false";
                        return;
                    }

                    if (fileSizeKB < 10 || fileSizeKB > 50) {
                        DevExpress.ui.notify("File size must be between 10KB and 50KB.", "error", 3000);
                        document.getElementById("PhotoValid").value = "false";
                        return;
                    }

                    // Preview the image
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        document.getElementById("profilePreview").src = e.target.result;
                    };
                    reader.readAsDataURL(file);

                    document.getElementById("PhotoValid").value = "true";
                }

                     document.addEventListener("DOMContentLoaded", function () {
                    const tabs = document.querySelectorAll('input[name="tab-effect-2"]');
                    const tabContents = document.querySelectorAll('.tab-content > div');

                    function showTab(index) {
                        tabContents.forEach((tab, i) => {
                            tab.classList.toggle("active-tab", i === index);
                            tabs[i].checked = (i === index);
                        });
                    }

                    // Tab click event
                    document.querySelectorAll('.tabs span').forEach((span, index) => {
                        span.addEventListener('click', () => showTab(index));
                    });

                    // Next button
                    document.querySelectorAll('.next-button').forEach((btn, index) => {
                        btn.addEventListener('click', () => {
                            if (index + 1 < tabContents.length) {
                                showTab(index + 1);
                            }
                        });
                    });

                    // Previous button
                    document.querySelectorAll('.prev-button').forEach((btn, index) => {
                        btn.addEventListener('click', () => {
                            if (index - 1 >= 0) {
                                showTab(index - 1);
                            }
                        });
                    });

                    // Show first tab on load
                    showTab(0);
                });
                         // 🏙 State Changed → Load Districts (permanent / correspondence)
                    function onStateChanged(e, flag) {
                        const stateId = e.value;
                        const targetSelectBoxId = flag === 'per' ? "District" : "CorresDistrict";
                        const districtBox = DevExpress.ui.dxSelectBox.getInstance(document.getElementById(targetSelectBoxId));

                        if (!districtBox) {
                            console.warn(`SelectBox with ID '${targetSelectBoxId}' not found.`);
                            return;
                        }

                        // Reset before loading
                        districtBox.option({ dataSource: [], value: null, isValid: true });

                        if (!stateId) return;

                        $.ajax({
                            url: '/Student/GetDistrictByStdID',
                            type: 'GET',
                            data: { stdId: stateId },

                            success: function (districts) {
                                debugger;
                                districtBox.option({
                                    dataSource: new DevExpress.data.DataSource({ store: districts }),
                                    displayExpr: "DistrictName",
                                    valueExpr: "DistrictId"
                                });

                                setTimeout(() => {
                                    if (typeof districtBox.validate === "function") {
                                        districtBox.validate();
                                    }
                                }, 100);
                            },
                            error: function () {
                                DevExpress.ui.notify('Failed to load districts.', 'error', 2000);
                            }
                        });

                    }
