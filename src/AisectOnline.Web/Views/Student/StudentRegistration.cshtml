                    // 📚 Load Programmes when Course Category changes
                       function onCourseCategoryChanged(e) {
            const courseCategoryId = e.value;
            const kioskTypeId = '@Model.KioskTypeID';
            const kioskId = '@Model.Kioskid';
           
            // Get Session ID safely
            const sessionBox = DevExpress.ui.dxSelectBox.getInstance(document.getElementById("Session"));
            const sessionId = sessionBox?.option("value");
            if (!courseCategoryId || !kioskTypeId || !sessionId || !kioskId) {
                DevExpress.ui.notify("Missing parameters", "error", 2000);
                return;
            }
            // Load Programmes based on selected Course Category
            $.ajax({
                url: `/Student/GetProgrammes`,
                type: "GET",
                data: {
                    KioskTypeID: kioskTypeId,
                    SessionId: sessionId,
                    CourseCategoryID: courseCategoryId,
                    KioskID: kioskId
                },
                success: function (data) {
                    debugger
                    const programBox = DevExpress.ui.dxSelectBox.getInstance(document.getElementById("Program"));
                    if (programBox) {
                        programBox.option({
                            dataSource: data,
                            valueExpr: "ValueField",
                            displayExpr: "TextField",
                            value: null
                        });
                        
                    } else {
                        console.warn("Program SelectBox not found.");
                    }
                },
                error: function () {
                    DevExpress.ui.notify("Failed to load Programmes", "error", 2000);
                }
            });

            // Safely call loadCourseFeeDetail with slight delay to ensure DOM is ready
            setTimeout(() => {
                if (typeof loadCourseFeeDetail === "function") {
                    loadCourseFeeDetail();
                } else {
                    console.warn("Function loadCourseFeeDetail not defined.");
                }
            }, 100);
            DevExpress.ui.dxSelectBox.getInstance(document.getElementById("Scheme")).option("value", null);
            DevExpress.ui.dxSelectBox.getInstance(document.getElementById("CourseMedium1")).option("value", null);
        }
