            <script>
                $(function () {
        // Tab track rakhne ke liye DX Tabs instance le lo
        var dxTabs = $("#dxTabs").dxTabs("instance");

        // Apne tab-wise required field lists yahan set karo (tab index ke order me, 0-based)
        var tabFieldMap = [
            // Tab 0: Course
            ["Session", "CourseCategory", "Program", "Scheme", "CourseFeeID", "CourseMedium1"],
            // Tab 1: Personal Details
            ["FirstName", "LastName", "FatherName", "MotherName", "Dob", "EmailAddress", "MobileNo", "MaritalStatus", "Sex", "Category", "DrivingLicenceType", "AadharNo", "ContactAddress", "VillageTownCity", "State", "Pin", "District"],
            // Tab 2: Education & Other Details
            ["AcademicQualification", "MainSubject", "YearOfPassing", "Division", "MarksPercentage", "BoardCode", "CourseMedium", "StudentBelongsTo", "Nationality", "FamilyIncomeYearly"],
            // Tab 3: Student Document (photo required)
            ["PhotoValid"],

            // Tab 5: Summary/tab (no validation, just view summary)
            []
        ];

        // Tab unlock/enable flag
        var unlockedTabs = [true, true, true, true, true, true];

        // Disable tabs visually except the first
        function updateTabs() {
            // Tabs ko disable visually
            var tabItems = $(".dx-tabs-wrapper .dx-tab");
            unlockedTabs.forEach(function (enabled, idx) {
                if (!enabled) tabItems.eq(idx).addClass("dx-state-disabled");
                else tabItems.eq(idx).removeClass("dx-state-disabled");
            });
        }

        // Next button logic
        window.nextTab = function () {
            var currentIndex = dxTabs.option("selectedIndex");
            // Form fields validate karo tabFieldMap ke hisab se
            var widgetIds = tabFieldMap[currentIndex];
            var allValid = true;

            widgetIds.forEach(function (id) {
                // Special case: photo
                if (id === "PhotoValid") {
                    if ($("#PhotoValid").val() !== "true") {
                        allValid = false;
                        DevExpress.ui.notify("Please upload a photo.", "error", 2000);
                    }
                    return;
                }
                var validator = $("#" + id).dxValidator ? $("#" + id).dxValidator("instance") : null;
                if (validator) {
                    var result = validator.validate();
                    if (!result.isValid) allValid = false;
                }
            });

            if (allValid) {
                // Unlock and activate next tab
                if (currentIndex + 1 < unlockedTabs.length) {
                    unlockedTabs[currentIndex + 1] = true;
                    updateTabs();
                    dxTabs.option("selectedIndex", currentIndex + 1);
                    // Form-sections show/hide (apke html me sections array ka use ho raha hai)
                    const sections = document.querySelectorAll('.form-section');
                    sections.forEach((s, i) => {
                        s.classList.remove('show', 'animate');
                        if (i === currentIndex + 1) {
                            s.classList.add('show');
                            requestAnimationFrame(() => s.classList.add('animate'));
                        }
                    });
                }
            } else {
                DevExpress.ui.notify("Please fill all required fields correctly.", "error", 2500);
            }
        };

        // Tab click par prevent karo agar tab unlock nahi hai
        $("#dxTabs").off("click").on("click", ".dx-tab", function (e) {
            var idx = $(this).index();
            if (!unlockedTabs[idx]) {
                e.preventDefault();
                e.stopPropagation();
                DevExpress.ui.notify("Please complete previous tab before proceeding.", "error", 2000);
            }
        });

        // Jab tab tab se change ho to bhi section show/hide ho
        var originalTabs = $("#dxTabs").dxTabs("instance");
        originalTabs.option("onSelectionChanged", function (e) {
            var selIdx = e.component.option("selectedIndex");
            const sections = document.querySelectorAll('.form-section');
            sections.forEach((s, i) => {
                s.classList.remove('show', 'animate');
                if (i === selIdx) {
                    s.classList.add('show');
                    requestAnimationFrame(() => s.classList.add('animate'));
                }
            });
        });

        // On load update visuals
        updateTabs();
    });

            </script>

