<script>
    const docOptions = ["5th","6th","7th","8th","9th","10th","11th","12th","Graduation","PG","Caste"];
    const maxUploads = 8;
    let uploads = [];

    const dropdownInstance = $("#documentDropdown").dxSelectBox({
      dataSource: docOptions,
      value: null,
      searchEnabled: true,
      placeholder: "Select document...",
      showClearButton: true,
      width: 320,
      label: "Please select document type",
      labelMode: "floating",
    }).dxSelectBox("instance");

    $("#choose-btn").dxButton({
      text: "Choose File",
      type: "success",
      onClick() {
        if (getAvailableDocTypes().length === 0) {
          alert("Max 8 uploads reached.");
          return;
        }
        if (!dropdownInstance.option('value')) {
          alert("Please select a document type for upload.");
          return;
        }
        $("#hiddenFileInput").click();
      }
    });

    $("#hiddenFileInput").on("change", function (e) {
      const files = e.target.files;
      if (files && files[0]) {
        const file = files[0];
        if (!file.name.toLowerCase().endsWith(".pdf")) {
          alert("Only PDF files are allowed.");
          return;
        }
        startProgressSim(file);
        $(this).val("");
      }
    });

    $("#dragArea").on("dragover", (e) => {
      e.preventDefault();
      $(e.currentTarget).css("border-color", "#4abd5d");
    }).on("dragleave", (e) => {
      $(e.currentTarget).css("border-color", "#bbb");
    }).on("drop", (e) => {
      e.preventDefault();
      $(e.currentTarget).css("border-color", "#bbb");
      const files = e.originalEvent.dataTransfer.files;
      if (files.length) startProgressSim(files[0]);
    }).on("click", () => {
      $("#choose-btn").click();
    });

    function getAvailableDocTypes() {
      return docOptions.filter(opt => !uploads.some(u => u.docType === opt && !u.removed));
    }
    function refreshDropdown() {
      const available = getAvailableDocTypes();
      dropdownInstance.option("dataSource", available);
      if (!available.includes(dropdownInstance.option('value'))) {
        dropdownInstance.option('value', null);
      }
      dropdownInstance.option("disabled", available.length === 0);
    }
    function removeUpload(docType) {
      const idx = uploads.findIndex(u => u.docType === docType && !u.removed);
      if (idx !== -1) {
        if (uploads[idx].url) URL.revokeObjectURL(uploads[idx].url);
        uploads[idx].removed = true;
      }
      renderUploads(); refreshDropdown();
    }
    window.removeUpload = removeUpload;

    window.viewPdf = function(idx) {
      const u = uploads[idx];
      const popupHtml = `
        <div class="pdf-popup-backdrop" onclick="closePdfPopup()"></div>
        <div class="pdf-popup" style="width:90%;height:90vh;overflow:hidden;position:fixed;">
          <span class="popup-close" onclick="closePdfPopup()">&#10005;</span>
          <div style="margin-bottom:8px;font-size:17px;font-weight:500;">${u.docType} : ${u.name}</div>
          <embed src="${u.url}" width="100%" height="90%" type="application/pdf" />
        </div>
      `;
      $('#pdf-popup-viewport').html(popupHtml).show();
    };
    window.closePdfPopup = function() {
      $('#pdf-popup-viewport').hide().html('');
    };

    function startProgressSim(file) {
      const docType = dropdownInstance.option("value");
      if (uploads.some(u => u.docType === docType && !u.removed)) return;
      if (!file.name.toLowerCase().endsWith(".pdf")) {
        alert("Only PDF files are allowed.");
        return;
      }
      if (uploads.length >= maxUploads) {
        alert("Maximum " + maxUploads + " uploads allowed.");
        return;
      }
      const fileUrl = URL.createObjectURL(file);
      uploads.push({
        docType,
        file,
        name: file.name,
        size: file.size,
        progress: 0,
        percent: 0,
        completed: false,
        removed: false,
        url: fileUrl
      });
      refreshDropdown();
      renderUploads();
      let idx = uploads.findIndex(u => u.docType === docType && !u.removed);
      let progress = 0;
      const totalSteps = 60;
      const duration = 1200;
      const stepMs = duration / totalSteps;
      function animate() {
        if (uploads[idx].removed) return;
        progress += 100 / totalSteps;
        uploads[idx].progress = progress > 100 ? 100 : progress;
        uploads[idx].percent = Math.floor(uploads[idx].progress);
        renderUploads();
        if (progress < 100) setTimeout(animate, stepMs);
        else {
          uploads[idx].progress = 100;
          uploads[idx].percent = 100;
          uploads[idx].completed = true;
          renderUploads();
        }
      }
      animate();
    }

    function renderUploads() {
      let html = "";
      uploads.filter(u => !u.removed).forEach((u, idx) => {
        html += `
          <div class="document-progress">
            <div style="display:flex;align-items:center;margin-bottom:4px;">
              <img src="https://cdn-icons-png.flaticon.com/512/337/337946.png" class="pdf-thumb" alt="PDF" onclick="viewPdf('${idx}')" title="View PDF" />
              <div style="margin-left:2px;font-size:16px;">${u.docType} - ${u.name} &nbsp; (${(u.size/1048576).toFixed(1)} MB)</div>
              <span class="remove-file" title="Remove" onclick="removeUpload('${u.docType}')">&#10005;</span>
            </div>
            <div class="progress-bar-container">
              <div class="progress-bar-fill" id="progressBar_${u.docType}"></div>
            </div>
            <span class="progress-count" id="progressCount_${u.docType}">Uploading... ${u.percent||0}%</span>
          </div>
        `;
      });
      $("#uploads").html(html);
      uploads.filter(u => !u.removed).forEach(u => {
        document.getElementById(`progressBar_${u.docType}`).style.width = `${u.progress}%`;
        document.getElementById(`progressCount_${u.docType}`).textContent = u.completed ? "Uploaded 100%" : `Uploading... ${u.percent||0}%`;
      });
    }

    renderUploads();
    refreshDropdown();
  </script>


