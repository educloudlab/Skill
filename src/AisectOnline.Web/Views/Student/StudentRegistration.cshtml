        $(document).ready(function () {
    $("#studentForm").on("submit", function (e) {
        e.preventDefault();

        var form = $(this)[0];
        var formData = new FormData(form);

        $.ajax({
            url: form.action,
            type: form.method,
            data: formData,
            processData: false,
            contentType: false,
            success: function (response) {
                console.log(response);
                debugger
                if (response && response.success && response.requestNo) {
                    DevExpress.ui.notify("Student created successfully!", "success", 2000);
                    disableFormFields("#studentForm"); 
                     document.querySelectorAll('.next-button').forEach((btn, index) => {
                        btn.addEventListener('click', () => {
                            if (index + 1 < tabContents.length) {
                                showTab(index + 1);
                            }
                        });
                    });
                } else {
                    DevExpress.ui.notify("Error: " + (response.error || "Unknown error"), "error", 3000);
                }
            },
            error: function (xhr) {
                DevExpress.ui.notify("Error: " + xhr.responseText, "error", 3000);
            }
        });
        nextTab();
    });

    function disableFormFields(formSelector) {
        var $form = $(formSelector);

        // disable normal inputs
        $form.find("input, textarea, select").attr("disabled", true);

        // disable DevExtreme widgets properly
        $form.find(".dx-widget").each(function () {
            var dxInstance = $(this).data("dxComponents");
            if (dxInstance) {
                dxInstance.forEach(function (compName) {
                    var instance = $(this)[compName]("instance");
                    if (instance && instance.option) {
                        instance.option("disabled", true);
                    }
                }, this);
            }
        });
    }
});


