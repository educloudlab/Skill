@using AisectOnline.Services.Modules.Students
@using DevExtreme.AspNet.Mvc
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model StudentRegistration1
@{
    ViewData["Title"] = "Student Admission";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />

<h2 class="page-title">Student Admission</h2>
@using (Html.BeginForm("StudentRegistration3", "Student", FormMethod.Post))
{
  
    @Html.Hidden("KioskTypeID", @Model?.kioskTypeID, new { id = "KiosktypeId" })
    @Html.Hidden("Kioskid", @Model?.kioskID, new { id = "Kioskid" })

    <div class="form-container">
      
        <!-- New Registration -->
        <div class="box">
            <h3><i class="fas fa-user-plus"></i> New Registration:</h3>

            <div class="form-group">
                <label>Select Center Type <span class="required">*</span></label>
                @(Html.DevExtreme().SelectBox().ID("Services").Name("Services_Id").DataSource(Model.Services).DisplayExpr("TextField").ValueExpr("ValueField").Placeholder("Please Select").Value(Model.Services_Id).InputAttr("aria-label", "Services ").OnValueChanged("function(e) { onCenterTypeChanged(e); }"))
            </div>

            <div class="form-group">
                <label>Admission In <span class="required">*</span></label>
                @(Html.DevExtreme().SelectBox().ID("Univercity").Name("Univercity_Id").DataSource(Model.Univercity).DisplayExpr("TextField").ValueExpr("ValueField").Value(Model.Univercity_Id).Placeholder("Please Select").InputAttr("aria-label", "Univercity"))
            </div>
            <div class="form-group">
                <label>CAPTCHA <span class="required">*</span></label>
                <div class="captcha-container" style="display:flex; align-items:center; gap:10px;">
                    <input type="hidden" id="CaptchaKey" name="CaptchaKey" value="@ViewBag.CaptchaKey" />

                    <img id="captchaImage" src="@Url.Action("CaptchaImage", "Student", new { key = ViewBag.CaptchaKey })" alt="CAPTCHA" style="height:40px;width:150px" />

                    <button type="button" onclick="refreshCaptcha()" class="refresh-btn btn btn-sm btn-secondary" style="margin:10px">
                        <i class="fas fa-sync-alt"></i>
                    </button>
                </div>
                @(Html.DevExtreme().TextBox()
                            .ID("captcha")
                            .Name("captcha") // must match your form model property
                            .Value(Model?.captcha) // bind value from model
                            .Placeholder("Enter CAPTCHA here")
                            .InputAttr("aria-label", "CAPTCHA Input")
                            .StylingMode(EditorStylingMode.Outlined)
                            .ShowClearButton(true)
                            .InputAttr("required", true)
                            )
            </div>

            <div class="form-group">
                @(Html.DevExtreme().Button()
                            .Text("Submit")
                            .Type(ButtonType.Normal)
                            .UseSubmitBehavior(true)
                            )
            </div>
        </div>

    
    </div>
}

<script>
    function refreshCaptcha() {
        const newKey = crypto.randomUUID();
        document.getElementById("CaptchaKey").value = newKey;
        document.getElementById("captchaImage").src = '@Url.Action("CaptchaImage", "Student")' + '?key=' + newKey + '&_=' + new Date().getTime();
    }


  function  onCenterTypeChanged(){
           const kioskId = '@Model.kioskID';
    const KioskTypeID = '@Model.kioskTypeID';
    debugger;
        $.ajax({
              url: `/Student/GetUniversity`,
            type: "GET",
            data: {
                    kioskId: kioskId,
                    KioskTypeID: KioskTypeID
            },
            success: function (data) {
                debugger;
                    const schemeSelectBox = DevExpress.ui.dxSelectBox.getInstance(document.getElementById("Univercity"));

                schemeSelectBox.option({
                    dataSource: data,
                      valueExpr: "ValueField",      // match key name in data
                      displayExpr: "TextField",     // match key name in data
                    value: null              // clear selection
                });
            },
            error: function () {
                DevExpress.ui.notify("Failed to load Scheme", "error", 2000);
            }
        });
    }

</script>