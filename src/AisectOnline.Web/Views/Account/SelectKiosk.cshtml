@model AisectOnline.Services.Modules.Accounts.IndexViewModel

@{
    Layout = "~/Views/Shared/LayoutBaseContent.cshtml";
}
<script type="text/javascript">
    function SelecKiosk() {
        var radios = document.getElementsByClassName("RadioSelect");
        var selectedValue = null;
        for (var i = 0; i < radios.length; i++) {
            if (radios[i].checked) {
                selectedValue = radios[i].value;
                break;
            }
        }

        if (!selectedValue) {
            alert("Please select a kiosk before continuing.");
            return false;
        }

        fetch('/Account/StoreSelectedKiosk/' + selectedValue)
            .then(() => {
                window.location.href = '/Home/Index';
            })
            .catch(err => {
                console.error(err);
                alert('Failed to store kiosk selection.');
            });
    }

    function selectRadio(el) {
        el.querySelector('input[type="radio"]').checked = true;
    }
</script>

<div id="login-modalSelectKiosk" style="
    display: block;
    position: fixed;
    z-index: 9999;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    font-family: 'Segoe UI', Tahoma, sans-serif;
">
    <div style="
        background-color: #fff;
        margin: 60px auto;
        padding: 30px;
        width: 90%;
        max-width: 480px;
        border-radius: 16px;
        position: relative;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        margin-top:10%;
    ">
        <span onclick="window.location.href='/Account/LogOn'" style="
            position: absolute;
            right: 18px;
            top: 12px;
            font-size: 26px;
            font-weight: bold;
            color: #888;
            cursor: pointer;
            transition: color 0.3s ease;
        " onmouseover="this.style.color='#000'" onmouseout="this.style.color='#888'">&times;</span>

        <h2 style="text-align: center; font-size: 22px; color: #333; margin-bottom: 25px; position: relative;">
            Select a Kiosk
            <span style="display:block; height:3px; width:50px; background:#007bff; margin:10px auto 0; border-radius:2px;"></span>
        </h2>

        @using (Html.BeginForm("SelectKiosk", "Account", FormMethod.Post, new { id = "SelectKiosk" }))
        {
            @Html.AntiForgeryToken()

            @if (Model.RadioList != null && Model.RadioList.Any())
            {
                <div>
                    @foreach (var kiosk in Model.RadioList)
                    {
                        <div class="kiosk-option" onclick="selectRadio(this)">
                            @Html.RadioButtonFor(m => m.TestRadio, kiosk.ValueField, new { @class = "RadioSelect", style = "margin-right:12px; transform:scale(1.2);" })
                            <span style="font-size: 15.5px; color: #333; font-weight: 500;">@Html.DisplayFor(modelItem => kiosk.TextField)</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p style="color: red;">No kiosks available.</p>
            }

            @Html.ValidationMessageFor(m => m.TestRadio, "", new { @style = "color:red; margin-top:10px; display:block;" })

            <div style="margin-top: 25px;">
                <button type="button" onclick="SelecKiosk()" style="
                            background-color: #007bff;
                            color: #fff;
                            padding: 12px 20px;
                            font-size: 16px;
                            border: none;
                            border-radius: 8px;
                            cursor: pointer;
                            width: 100%;
                            box-shadow: 0 4px 12px rgba(0,123,255,0.3);
                            transition: background 0.3s ease;
                        " onmouseover="this.style.background='#0056b3'" onmouseout="this.style.background='#007bff'">
                    Continue
                </button>
            </div>
        }
    </div>
</div>
<style>
    .kiosk-option {
        display: flex;
        align-items: center;
        padding: 12px;
        margin: 6px 0;
        background: #f3f6f9;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.3s;
    }

        .kiosk-option:hover {
            background: #e6efff;
        }

        .kiosk-option input[type="radio"] {
            margin-right: 10px;
            pointer-events: none;
        }
</style>