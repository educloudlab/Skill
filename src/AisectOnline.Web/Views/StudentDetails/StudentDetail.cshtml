<script>



    function validateString(input) {
            var regex = /^[A-Za-z\s]*$/;
            var errorMessage = document.getElementById('error-message');
            
            if (!regex.test(input.value)) {
                input.value = input.value.replace(/[^A-Za-z\s]/g, ''); // Remove non-string characters
                errorMessage.textContent = "Numbers are not allowed!";
            } else {
                errorMessage.textContent = ""; // Clear the error message
            }
        }


		function validateInteger(input) {
    var regex = /^[0-9]*$/; // Regular expression to allow only digits (0-9)
    var errorMessage = document.getElementById('error-message');

    // Check if the input contains any non-integer characters
    if (!regex.test(input.value)) {
        input.value = input.value.replace(/[^0-9]/g, ''); // Remove non-numeric characters
        errorMessage.textContent = "Only integers are allowed!";
    } 
    // Check if the length is not equal to 6
    else if (input.value.length< 7) {
        errorMessage.textContent = "Input must be exactly 6 digits!";
    } 
    else {
        errorMessage.textContent = ""; // Clear the error message
    }



	function validationIntegerAdd(input)
	{
		var regex=/^[0-9]*$/;
		var errorMessage=document.getElementById('error message');
		if(!regex.test(input.value)){
			input.value=input.value.replace(/[^0-9]/g,'');
			errorMessage.textContent="Only integers are allowed!";
		}
		else if(input.value.length!=12)
		{
			errorMessage.textContent="Input Must be exactly 12 digits";
		}
		else
		{
			errorMessage.textContent="";
		}
	}
}



$(document).ready(function() {
    $('#dropdown').change(function() {
        var stateId = $(this).val(); // Get the selected stateId
        $('#hdnstateID').val(stateId); // Set the hidden input value

        if (stateId) {
            $.ajax({
                url: '@Url.Action("GetDistricts", "StudentDetails")', // Call the GetDistricts action
                type: 'GET',
                dataType: 'json',
                data: { stateId: stateId }, // Pass the stateId as data
                success: function(data) {
                    var $districtId = $('#districtId'); // Get the district dropdown element
                    $districtId.empty(); // Clear previous options
                    $districtId.append('<option value="">Select District</option>'); // Add a default option

                    // Loop through the returned data and populate the dropdown
                    $.each(data, function(index, item) {
                        console.log(item); // Debug: log each item (District) for verification
                        $districtId.append($('<option>').val(item.DistrictId).text(item.DistrictName));
                    });
                },
                error: function(xhr, status, error) {
                    console.error("Error fetching districts:", status, error); // Handle errors
                }
            });
        } else {
            // Reset district dropdown if no state is selected
            $('#districtId').empty().append('<option value="">Select District</option>');
        }
    });
});



//$('#btnsave').click(function(){

//	$('#skpDropdownText')

//});



</script>


<script>

	 function loadZone(ZoneId) {
            $.getJSON('@Url.Action("GetState", "StudentDetails")', { ZoneId: ZoneId }, function (data) {
                var stateDropdown = $('#Stateid');
                stateDropdown.empty();
                stateDropdown.append('<option value="">-- Select District --</option>');
                $.each(data, function (index, item) {
                    stateDropdown.append('<option value="' + item.StateID + '">' + item.StateName + '</option>');
                });
            });
        }
        function loadState(stateId) {
            $.getJSON('@Url.Action("GetDistricts", "StudentDetails")', { stateId: stateId }, function (data) {
                var districtDropdown = $('#districtId');
                districtDropdown.empty();
                districtDropdown.append('<option value="">-- Select District --</option>');
                $.each(data, function (index, item) {
                    districtDropdown.append('<option value="' + item.DistrictId + '">' + item.DistrictName + '</option>');
                });
            });
        }

        function loadDistricts(districtId) {
            $.getJSON('@Url.Action("GetKiosksByDistrict", "StudentDetails")', { districtId: districtId }, function (data) {
                var skpDropdown = $('#SKPid');
                skpDropdown.empty();
                skpDropdown.append('<option value="">-- Select SKP --</option>');
                $.each(data, function (index, item) {
                    skpDropdown.append('<option value="' + item.KIOSKID + '">' + item.KioskCode + '</option>');
                });
            });
        }


 

    </script>




