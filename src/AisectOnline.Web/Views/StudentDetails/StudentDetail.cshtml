@using AisectOnline.Services.Modules
@{
    ViewData["Title"] = "Student Information";
}

    
<html>
<body>
    <div class="form-container">
        <div class="ScrollStyle">		
			<br>
			<img src="/images/img.jpeg" style="width: 100%;" alt="Description of image">

			 <br/>
			  @if (TempData["Result"] != null)
              {
                <div class="alert alert-success" style="text-align:center;font-size:18px; font-weight:bold; margin-left:0px">@TempData["Result"]</div>
              }
		
 @using (Html.BeginForm("setStudentDetail", "StudentDetails", FormMethod.Post,  new { id = "admissionForm" }))
 {
          
			<div class="section">
				<div class="form-row">
	     
                <div class="form-group">
				<label for="Zoneid">Zone</label>
                <select id="Zoneid" name="Zoneid" class="form-control" onchange="loadZone(this.value)" required>
                    <option value="">Select Zone</option>

					@if(ViewBag.Zone!=null)
					{
                    @foreach (var Zone in ViewBag.Zone)
                    {
                        <option value="@Zone.Value">@Zone.Text</option>
                    }
					}
                </select>
            </div>

			        <div class="form-group">
						<label for="Stateid">State:</label>
						 <select id="Stateid" name="Stateid" class="form-control" onchange="loadState(this.value)" required>
						<option value="">Select State</option>   </select>
					</div>

					<div class="form-group">
						<label for="districtId">District:</label>
						 <select id="districtId" name="districtId" class="form-control" onchange="loadDistricts(this.value)" required>
						<option value="">Select District</option>   </select>
					</div>


					
				
				</div>

				<div class="form-row">
                      <div class="form-group">
						<label for="SKPid">SKP:</label>
						 <select id="SKPid" name="SKPid" class="form-control" required>
						<option value="">Select SKP</option>   </select>
					</div>
			
					<div class="form-group">
						<label for="studname">Student Name</label>
						<input type="text" placeholder="Enter Student Name..." id="studname" name="studname" oninput="validateString(this)" required>
					</div>
					<div class="form-group">
						<label for="fathername">Father Name</label>
						<input type="text" placeholder="Enter Father Name..." id="fathername" name="fathername" oninput="validateString(this)" required>
					</div>
				</div>
			
				<div class="form-row">

					<div class="form-group">
						<label for="mothername">Mother Name</label>
						<input type="text" placeholder="Enter Mother Name..." id="mothername" name="mothername" oninput="validateString(this)" required>
					</div>

					<div class="form-group">
						<label for="Guardian">Guardian Name</label>
						<input type="text" placeholder="Enter Guardian Name..." id="Guardian" name="Guardian" oninput="validateString(this)" required>
					</div>
						<div class="form-group">
						<label for="dob">Date of Birth:</label>
						<input type="date" id="dob" name="dob" required>
					</div>
					</div>
				    <div class="form-row">				
					   <div class="form-group">
						 <label for="gender">Gender</label>
						    <select id="gender" name="gender" required>
							<option value="">Select a Gender</option>
							<option value="Male">Male</option>
							<option value="Female">Female</option>
							<option value="Other">Other</option>
						   </select>
					</div>
				
					<div class="form-group">
						<label for="category">Category</label>
						<select id="category" name="category" required>
							<option value="">Select a Category</option>
							<option value="General">General</option>
							<option value="OBC">OBC</option>
							<option value="SC">SC</option>
							<option value="ST">ST</option>
						</select>
					</div>

					<div class="form-group">
						<label for="email">Email</label>
						<input type="email" placeholder="Enter Your Email" id="email" name="email" required>
					</div>
					


			  </div>
			
				
			
				<div class="form-row">

					<div class="form-group">
						<label for="mobile">Mobile</label>
						<input type="tel" placeholder="Enter Your Mobile No" id="mobile" maxlength="10" oninput="validateInteger(this)" name="mobile" required>
					</div>
					<div class="form-group">
						<label for="aadhar">Aadhar No</label>
						<input type="text" placeholder="Enter Your Aadhar No" id="aadhar" maxlength="12" oninput="validationIntegerAdd" name="aadhar" required>
					</div>


					
					<div class="form-group">
						<label for="Address">Address</label>
						<input type="text" placeholder="Enter Your Address..." id="address" name="address" required>
					</div>
					
					

				</div>
			
				<div class="form-row">
					
					<div class="form-group">
						<label for="city">City:</label>
					<input type="text" placeholder="Enter Your City..." id="city" name="city" oninput="validateString(this)" required">
					</div>
					<div class="form-group">
						<label for="pin">Pin Code</label>
						<input type="text" placeholder="Enter Pin Code..." id="pin" name="pin" maxlength="6" oninput="validateInteger(this)" required>
										 
				</div>
					<div class="form-group">
						<label for="Education">Education</label>
						 <select id="Education" name="Education" class="form-control" required>
                    <option value="">Select Education</option>
					@if(ViewBag.Education!=null)
					{
                    @foreach (var Edu in ViewBag.Education)
                    {
                        <option value="@Edu.Text">@Edu.Text</option>
                    }
					}
                    </select>


					</div>					  
				</div>
				<div class="form-row">				  
		    <div class="form-group">
						<label for="Specialization">Specialization</label>
						<input type="text" placeholder="Enter Your Specialization" id="Specialization" name="Specialization" required>
					   </div>

				<div class="form-group">
						<label for="Medium">Medium</label>
						<select id="Medium" name="Medium" required>
							<option value="">Select Medium</option>
							<option value="Hindi">Hindi</option>
							<option value="English">English</option>
							<option value="Other">Other</option>
						</select>
					</div>


				<div class="form-group">
					<label for="board">Board</label>
					<input type="text" placeholder="Enter Board" id="board" name="board" required>
				</div>
			</div>
			<div class="form-row">
			      <div class="form-group">
					<label for="year">Passing Year</label>
					<input type="number" placeholder="Enter Year" id="year" name="year" required>
				</div>				

					 <div class="form-group">
						<label for="Division">Division:</label>
						 <select id="Division" name="Division" class="form-control" required>
						<option value="">Select Division</option>
						<option value="I">I</option>
						<option value="II">II</option>
						<option value="III">III</option>					
					</select>
					</div>


					<div class="form-group">
						<label for="projectname">Project Name</label>
						<input type="text" placeholder="Enter Project Name" id="projectname" name="projectname" required>
					</div>
					
			</div>

				
			
				<div class="form-row">
						
				<div class="form-group">
						<label for="projectfy">Project FY</label>
						<input type="text" placeholder="Enter Project FY" id="projectfy" name="projectfy" required>
					</div>

					 <div class="form-group">
						<label for="Funded">Funded By:</label>
						 <select id="Funded" name="Funded" class="form-control" required>
						<option value="">Select Funded By</option>
						<option value="CSR">CSR</option>
						<option value="GOVT">GOVT</option>
						<option value="Schools">Schools</option>					
					</select>
					</div>


			

					<div class="form-group">
						<label for="Assessment">Assessment Mode:</label>
						 <select id="Assessment" name="Assessment" class="form-control" required>
						<option value="">Select Assessment Mode</option>
						<option value="SSC">SSC</option>
						<option value="NON SSC">NON SSC</option>										
					</select>
					</div>					
			
				
				
				

					
				</div>
			
				<div class="form-row">

					<div class="form-group">
			        <label for="Placement">Placement Oriented:</label>
					 <select id="Placement" name="Placement" class="form-control" required>
                    <option value="">Select Placement Oriented</option>
					 <option value="YES">YES</option>
					  <option value="NO">NO</option>                  
                     </select>
					</div>


						<div class="form-group">
						<label for="Sectors">Sector Name:</label>

					 <select id="Sector" name="Sector" class="form-control" required>
                    <option value="">Select Sector</option>
								@if (ViewBag.Sector != null)
								{
									@foreach (var Sector in ViewBag.Sector)
									{
										<option value="@Sector.Text">@Sector.Text</option>
									}
								}
							</select>



					</div>

					<div class="form-group">
						<label for="coursecode">Course Code QP Code</label>
						<input type="text" placeholder="Enter Course Code QP Code" id="coursecode" name="coursecode" required>
					</div>
					
					
				</div>
			
				<div class="form-row">

					<div class="form-group">
						<label for="coursename">Course Name</label>
						<input type="text" placeholder="Enter Course Name" id="coursename" name="coursename" required>
					</div>

					<div class="form-group">
						<label for="batchid">Batch ID</label>
						<input type="number" placeholder="Enter Batch ID" id="batchid" name="batchid" required>
					</div>

					 <div class="form-group">
						<label for="Entity">Aisect Entity:</label>
						 <select id="Entity" name="Entity" class="form-control" required>
						<option value="">Select Aisect Entity</option>
						<option value="Aisect Limited">Aisect Limited</option>
						<option value="Aisect Society Bhopal">Aisect Society Bhopal</option>
						<option value="Aisect Society Raipur">Aisect Society Raipur</option>					
					</select>
					</div>
				</div>
				<div class="form-row">
					 <div class="form-group">
						<label for="StudentCertified">Student Certified:</label>
						 <select id="StudentCertified" name="StudentCertified" class="form-control" required>
						<option value="">Select Student Certification</option>
						<option value="Yse">Yes</option>
						<option value="No">No</option>
											
					</select>
					</div>

					 <div class="form-group">
						<label for="StudentPlaced">Student Placed:</label>
						 <select id="StudentPlaced" name="StudentPlaced" class="form-control" required>
						<option value="">Select No.Of Student Placed</option>
						<option value="Yes">Yes</option>
						<option value="No">No</option>					   			
					</select>
					</div>
				  
					<div class="form-group">
						<label for="createdby">Created By</label>
						<input type="text" placeholder="Enter Created By" id="createdby" name="createdby" required>
					</div>
				</div>
			
				<button type="submit" id="btnsave" name="btnsave" style="background-color: #004b80;color: white;font-weight: 600;width:32%; height:-16px; margin-top: 2%;">Submit</button>
						
			</div>
          }
		  </div></div>


</body>

</html>

