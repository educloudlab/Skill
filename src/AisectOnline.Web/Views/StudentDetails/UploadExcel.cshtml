    @section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {           

            //debugger;
            $('#dropdown').change(function () {
                var stateId = $(this).val(); 
               
                $('#hdnstateID').val(stateId);
              
                if (stateId) {
                    $.ajax({
                        url: '@Url.Action("GetDistricts", "StudentDetails")',
                        type: 'GET',
                        dataType: 'json',
                        data: { stateId: stateId },
                        success: function (data) {
                            var $districtDropdown = $('#districtDropdown');
                            $districtDropdown.empty();
                            $districtDropdown.append('<option value="">Select District</option>');
                            $.each(data, function (index, item) {
                                //debugger;
                                $districtDropdown.append($('<option>').val(item.DistrictId).text(item.DistrictName));
                            });
                        }
                    });
                    
                } else {
                    $('#districtDropdown').empty().append('<option value="">Select District</option>');
                }
            });


     
        $('#uploadForm').submit(function(event) {
        $('#img').show(); 
        debugger;
        var dropdown = $("#dropdown option:selected").text();
        var validationMessageSate = $('#validationMessageSate');
        validationMessageSate.text(''); // Clear previous validation messages

        if (dropdown === "Please select State") {
            validationMessageSate.text('Please select State');
            event.preventDefault(); 
            return false;
        }

        var dropdownDist = $("#districtDropdown option:selected").text();
        var validationMessagedist = $('#validationMessagedist');
        validationMessagedist.text(''); 
        if (dropdownDist === "Select District") {
            validationMessagedist.text('Please select District');
            event.preventDefault(); 
            return false;
        }

        var dropdownskp = $("#SKPDropdown option:selected").text();
        var validationMessageskp = $('#validationMessageskp');
        validationMessageskp.text(''); 
        if (dropdownskp === "Select SKPID") {
            validationMessageskp.text('Please select SKP');
            event.preventDefault(); 
            return false;
        }

        // File validation
        event.preventDefault(); 
        var formData = new FormData();
        var fileInput = $('#fileInput')[0].files[0];
        var validationMessage = $('#fileValidationMessage');
        validationMessage.text(''); // Clear previous validation messages

        if (!fileInput) {
            validationMessage.text('Please select a file.');
            return false;
        }
        
        else {
             // debugger;
            var district = $('#hdnDistrictID').val();
            var State = $('#hdnstateID').val();
            var skp = $('#hdnSKPID').val();
           
            formData.append('file', fileInput);
            formData.append('State', State);
            formData.append('district', district);
            formData.append('skp', skp);

            
            $.ajax({
                url: '@Url.Action("saveUploadExcel", "StudentDetails")',
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,

                success: function(data) {
                    
                    alert(data);
                 $('#img').hide();
                   window.location.reload();
              
                    $('#fileInput').val('');
                },
                error: function(jqXHR, textStatus, errorThrown) {
                    validationMessage.text('An error occurred while uploading the file.');
                }
            });
        }
    });


        });


    </script>



