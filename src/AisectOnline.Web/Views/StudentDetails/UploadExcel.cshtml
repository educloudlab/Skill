<style>
    .scrollable-table {
        max-height: 400px;  
        overflow-y: auto;
    }
</style>
<script>
    var currentPage = 0;
    var recordsPerPage = 10;
    var data = [];

    // Function to display data in the table
    function displayData() {
        var start = currentPage * recordsPerPage;
        var end = start + recordsPerPage;
        var paginatedData = data.slice(start, end);
        var container = document.getElementById('dataContainer');
        container.innerHTML = "";

        if (paginatedData.length > 0) {
            let tableHtml = '<table class="table table-striped">';
            tableHtml += '<thead><tr>';
            var columns = [
                "SKP Id", "Registration No", "Student Name", "Father Name", "Mother Name", "Guardian Name", 
                "Address", "City", "District", "State", "PinCode", "Zone", "DOB", "Gender", "Category", 
                "Email", "Mobile", "AadharNo", "Education", "Specialization", "Medium", "Board", "Year", 
                "Division", "Project Name", "Funded By", "Assessment Mode", "Project FY", "Placement", 
                "Sector Name", "Course_Code_QP_Code", "Course Name", "Batch Id", "Aisect Entity", 
                "Student Certified", "Student Placed", "Created By", "Created On", "LotNo"
            ];

            columns.forEach(function (column) {
                tableHtml += '<th>' + column + '</th>';
            });
            tableHtml += '</tr></thead><tbody>';

            paginatedData.forEach(function (row) {
                tableHtml += '<tr>';
                row.forEach(function (cell) {
                    tableHtml += '<td>' + cell + '</td>';
                });
                tableHtml += '</tr>';
            });

            tableHtml += '</tbody></table>';
            container.innerHTML = tableHtml;
        } else {
            container.innerHTML = '<p>No data to display.</p>';
        }

        // Update data info
        document.getElementById('dataInfo').innerText = 'Showing ' + (start + 1) + ' to ' + Math.min(end, data.length) + ' of ' + data.length;

        // Disable pagination buttons if at start or end
        document.getElementById('prevBtn').disabled = currentPage === 0;
        document.getElementById('nextBtn').disabled = end >= data.length;
    }

    // Pagination: Previous Button
    document.getElementById('prevBtn').addEventListener('click', function () {
        if (currentPage > 0) {
            currentPage--;
            displayData();
        }
    });

    // Pagination: Next Button
    document.getElementById('nextBtn').addEventListener('click', function () {
        if ((currentPage + 1) * recordsPerPage < data.length) {
            currentPage++;
            displayData();
        }
    });

    // Fetch data from the server and display
    $(document).ready(function () {
        $('#fetchDataBtn').click(function () {
            $('#dataContainer').html('<p>Loading...</p>');
            getDisplayData();
        });
    });

    function getDisplayData() {
        $.ajax({
            url: '@Url.Action("DisplayData", "Studentdetails")', 
            type: 'GET',
            dataType: 'json',
            success: function(response) {
                if (response && response.rows && response.columns) {
                    data = response.rows;
                    displayData();
                    populateLotNoDropdown();
                    $('#dataModal').modal('show');
                } else {
                    $('#dataContainer').html('<p>No data available.</p>');
                }
            },
            error: function (xhr, status, error) {
                $('#dataContainer').html('<p>Error fetching data: ' + error + '</p>');
            }
        });
    }

    // Populate LotNo dropdown with unique LotNos
    function populateLotNoDropdown() {
        var lotNos = [...new Set(data.map(item => item[item.length - 1]))]; // Assuming LotNo is the last column
        var dropdown = $('#lotnoDropdown');
        dropdown.empty();
        dropdown.append('<option value="">Select Lot No.</option>');

        lotNos.forEach(function(lotNo) {
            dropdown.append('<option value="' + lotNo + '">' + lotNo + '</option>');
        });
    }

    // Delete all displayed records
    function deleteAllRecords() {
        if (confirm("Are you sure you want to delete all displayed records?")) {
            data = [];
            displayData();
            alert("All records have been deleted.");
        }
    }

    // Delete records based on selected LotNo
    function deleteRecordsByLotNo(lotNo) {
       
        if (!lotNo) {
            alert("Please select a LotNo.");
            return;
        }

        if (confirm("Are you sure you want to delete all records for LotNo: " + lotNo + "?")) {

            deleteRecord(lotNo)

            //var filteredRecords = data.filter(function(record) {  
            //    return record[record] === lotNo;
            //   // return record[record.length - 1] === lotNo; // Assuming LotNo is the last column
            //});

           
            //filteredRecords.forEach(function(record) {
            //    alert(record);
            //    var recordId = record[0]; // Assuming the first column is the ID
            //     alert(recordId);
            //    deleteRecord(recordId);
            //});

            //displayData();
        }
    }

    // Delete individual record
    function deleteRecord(recordId) {
            $.ajax({
            url: '@Url.Action("DeleteAllRecords", "Studentdetails")', 
            type: 'Post',
             //dataType: 'json',
            data: {id: recordId },           
            success: function(response) {
                if (response.success) {
                     data = [];
                     getDisplayData();
                     alert("Record deleted successfully.");

                } else {
                    alert("Error deleting record.");
                }
            },
                error: function(xhr, status, error) {
                alert("Error deleting record: " + error);
            }
        });
    }

    // Event listener for "Delete Records of Selected LotNo" button
    $('#deleteLotRecordsBtn').click(function () {
        var selectedLotNo = $('#lotnoDropdown').val();
        deleteRecordsByLotNo(selectedLotNo);
    });

    // Event listener for "Delete All" button
    $('#deleteAllBtn').click(function () {
        deleteAllRecords();
    });
</script>


